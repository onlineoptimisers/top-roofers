---
import { SITE } from '../data/site';

interface Props {
  title: string;
  description?: string;
  schema?: object | object[];
  canonical?: string;
}

const {
  title,
  description = SITE.description,
  schema,
  canonical,
} = Astro.props;

const currentPath = Astro.url.pathname;

const nav = [
  { href: '/', label: 'Home' },
  { href: '/services/roof-replacement/', label: 'Roof Replacement' },
  { href: '/services/storm-damage/', label: 'Storm Damage' },
  { href: '/services/roof-repair/', label: 'Repairs' },
  { href: '/services/roof-inspection/', label: 'Inspections' },
  { href: '/projects/', label: 'Projects' },
  { href: '/about/', label: 'About' },
];

const schemas = Array.isArray(schema) ? schema : schema ? [schema] : [];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {canonical && <link rel="canonical" href={canonical} />}
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    @import "../styles/global.css";
    body { font-family: 'Manrope', system-ui, sans-serif; }
  </style>
  {schemas.map(s => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
  ))}
</head>
<body class="bg-brand-light text-brand-navy min-h-screen flex flex-col">

  <!-- Top bar -->
  <div class="bg-brand-navy text-white text-sm py-2 hidden md:block">
    <div class="max-w-7xl mx-auto px-4 flex justify-between items-center">
      <span>Serving Hill Country &amp; Austin Metro</span>
      <div class="flex gap-6">
        <a href={`tel:${SITE.phones.hillCountryTel}`} class="hover:text-brand-accent-light transition">
          Hill Country: {SITE.phones.hillCountry}
        </a>
        <a href={`tel:${SITE.phones.austinTel}`} class="hover:text-brand-accent-light transition">
          Austin: {SITE.phones.austin}
        </a>
      </div>
    </div>
  </div>

  <!-- Nav -->
  <nav class="bg-white shadow-sm sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 font-bold text-xl text-brand-navy">
        <svg class="w-8 h-8 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M3 21h18M3 21V9l9-7 9 7v12M9 21v-6h6v6" />
        </svg>
        <span>Red Roan<span class="text-brand-accent"> Construction</span></span>
      </a>

      <div class="hidden lg:flex items-center gap-5 text-sm font-medium">
        {nav.slice(1, -2).map(link => (
          <a
            href={link.href}
            class={`hover:text-brand-accent transition ${currentPath.startsWith(link.href) ? 'text-brand-accent' : 'text-brand-navy'}`}
          >{link.label}</a>
        ))}
        <a href="/projects/" class={`hover:text-brand-accent transition ${currentPath.startsWith('/projects') ? 'text-brand-accent' : 'text-brand-navy'}`}>Projects</a>
        <a href="/about/" class={`hover:text-brand-accent transition ${currentPath === '/about/' ? 'text-brand-accent' : 'text-brand-navy'}`}>About</a>
        <a href="/contact/" class="bg-brand-accent text-white px-4 py-2 rounded-lg font-semibold hover:bg-brand-accent-light transition">
          Free Quote
        </a>
      </div>

      <button id="mobile-menu-btn" class="lg:hidden p-2 text-brand-navy" aria-label="Menu">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <div id="mobile-menu" class="hidden lg:hidden bg-white border-t border-slate-100 px-4 pb-4">
      {nav.map(link => (
        <a href={link.href} class="block py-3 text-sm font-medium border-b border-slate-50 text-brand-navy hover:text-brand-accent">{link.label}</a>
      ))}
      <a href="/contact/" class="block mt-3 text-center bg-brand-accent text-white py-3 rounded-lg font-semibold">Free Quote</a>
    </div>
  </nav>

  <main class="flex-1">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="bg-brand-navy text-white pt-16 pb-8">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid md:grid-cols-4 gap-8 pb-12 border-b border-white/10">
        <div class="md:col-span-2">
          <div class="flex items-center gap-2 font-bold text-xl mb-4">
            <svg class="w-7 h-7 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M3 21h18M3 21V9l9-7 9 7v12M9 21v-6h6v6" />
            </svg>
            Red Roan Construction
          </div>
          <p class="text-white/60 text-sm leading-relaxed max-w-sm">
            Your trusted partner for roofing and general construction needs across the Texas Hill Country and Austin metro. {SITE.years} years in business. {SITE.warranty}.
          </p>
          <div class="mt-6 space-y-2 text-sm">
            <a href={`tel:${SITE.phones.hillCountryTel}`} class="flex items-center gap-2 text-white/80 hover:text-brand-accent-light transition">
              <svg class="w-4 h-4 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              Hill Country: {SITE.phones.hillCountry}
            </a>
            <a href={`tel:${SITE.phones.austinTel}`} class="flex items-center gap-2 text-white/80 hover:text-brand-accent-light transition">
              <svg class="w-4 h-4 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              Austin: {SITE.phones.austin}
            </a>
            <a href={`mailto:${SITE.email}`} class="flex items-center gap-2 text-white/80 hover:text-brand-accent-light transition">
              <svg class="w-4 h-4 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              {SITE.email}
            </a>
          </div>
        </div>

        <div>
          <h4 class="font-semibold mb-4 text-sm tracking-wide uppercase text-white/40">Services</h4>
          <ul class="space-y-2 text-sm text-white/70">
            <li><a href="/services/roof-replacement/" class="hover:text-brand-accent-light transition">Roof Replacement</a></li>
            <li><a href="/services/storm-damage/" class="hover:text-brand-accent-light transition">Storm Damage</a></li>
            <li><a href="/services/roof-repair/" class="hover:text-brand-accent-light transition">Roof Repair</a></li>
            <li><a href="/services/roof-inspection/" class="hover:text-brand-accent-light transition">Roof Inspection</a></li>
          </ul>
        </div>

        <div>
          <h4 class="font-semibold mb-4 text-sm tracking-wide uppercase text-white/40">Company</h4>
          <ul class="space-y-2 text-sm text-white/70">
            <li><a href="/about/" class="hover:text-brand-accent-light transition">About Us</a></li>
            <li><a href="/projects/" class="hover:text-brand-accent-light transition">Projects</a></li>
            <li><a href="/contact/" class="hover:text-brand-accent-light transition">Contact</a></li>
          </ul>
        </div>
      </div>

      <div class="pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-white/40">
        <p>&copy; {new Date().getFullYear()} Red Roan Construction. All rights reserved.</p>
        <p>Serving Hill Country &amp; Austin Metro, Texas</p>
      </div>
    </div>
  </footer>

  <script>
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
  </script>
</body>
</html>
