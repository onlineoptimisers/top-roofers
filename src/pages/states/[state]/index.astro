---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BreadcrumbNav from '../../../components/BreadcrumbNav.astro';
import { getAllStates, getCitiesByState, getStateName } from '../../../lib/data';

export function getStaticPaths() {
  const states = getAllStates();
  return states.map(s => ({
    params: { state: s.slug },
    props: { stateMeta: s },
  }));
}

const { stateMeta } = Astro.props;
const cities = getCitiesByState(stateMeta.state);
const stateName = getStateName(stateMeta.state);
---

<BaseLayout
  title={`Best Roofers in ${stateName} | TopRoofers`}
  description={`Find trusted roofing contractors in ${stateName}. ${stateMeta.count} verified roofers across ${cities.length} cities.`}
>
  <div class="max-w-7xl mx-auto px-4 py-8">
    <BreadcrumbNav crumbs={[
      { label: 'Home', href: '/' },
      { label: 'States', href: '/states/' },
      { label: stateName, href: `/states/${stateMeta.slug}/` },
    ]} />

    <h1 class="text-3xl font-bold text-brand-navy mb-2">Roofers in {stateName}</h1>
    <p class="text-brand-muted mb-8">{stateMeta.count} verified roofing contractors in {cities.length} cities</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {cities.map(city => (
        <a
          href={`/states/${stateMeta.slug}/${city.slug}/`}
          class="bg-white rounded-xl p-6 shadow-sm hover:shadow-md border border-slate-100 transition-all hover:-translate-y-0.5 group"
        >
          <h2 class="text-lg font-semibold text-brand-navy group-hover:text-brand-accent transition">
            {city.city}
          </h2>
          <p class="text-sm text-brand-muted mt-1">
            {city.count} roofers &middot; {city.avgRating.toFixed(1)} avg rating
          </p>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
