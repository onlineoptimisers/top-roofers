---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import BreadcrumbNav from '../../../../components/BreadcrumbNav.astro';
import ReviewStars from '../../../../components/ReviewStars.astro';
import ClaimCTA from '../../../../components/ClaimCTA.astro';
import { getAllListings, getAllCities, getStateName, getStateSlug } from '../../../../lib/data';

export function getStaticPaths() {
  const listings = getAllListings();
  const cities = getAllCities();

  return listings.map(l => {
    const cityMeta = cities.find(c => c.city === l.city && c.state === l.state);
    return {
      params: {
        state: cityMeta?.stateSlug || getStateSlug(l.state),
        city: cityMeta?.slug || l.city.toLowerCase().replace(/[^a-z0-9]+/g, '-'),
        slug: l.slug,
      },
      props: { listing: l, cityMeta },
    };
  });
}

const { listing, cityMeta } = Astro.props;
const stateName = getStateName(listing.state);
const stateSlug = cityMeta?.stateSlug || getStateSlug(listing.state);
const citySlug = cityMeta?.slug || listing.city.toLowerCase().replace(/[^a-z0-9]+/g, '-');

const schema = {
  '@context': 'https://schema.org',
  '@type': 'RoofingContractor',
  name: listing.title,
  telephone: listing.phone,
  url: listing.url,
  address: {
    '@type': 'PostalAddress',
    streetAddress: listing.address.split(',')[0]?.trim(),
    addressLocality: listing.city,
    addressRegion: listing.state,
    postalCode: listing.zip,
    addressCountry: 'US',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: listing.lat,
    longitude: listing.lng,
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: listing.rating,
    reviewCount: listing.reviews,
    bestRating: 5,
  },
  areaServed: {
    '@type': 'City',
    name: listing.city,
  },
};
---

<BaseLayout
  title={`${listing.title} - ${listing.city}, ${listing.state} | Reviews & Contact | TopRoofers`}
  description={`${listing.title} in ${listing.city}, ${stateName}. Rated ${listing.rating}/5 with ${listing.reviews} reviews. Contact: ${listing.phone}.`}
  schema={schema}
>
  <div class="max-w-4xl mx-auto px-4 py-8">
    <BreadcrumbNav crumbs={[
      { label: 'Home', href: '/' },
      { label: stateName, href: `/states/${stateSlug}/` },
      { label: listing.city, href: `/states/${stateSlug}/${citySlug}/` },
      { label: listing.title, href: `/states/${stateSlug}/${citySlug}/${listing.slug}/` },
    ]} />

    <!-- Business Header -->
    <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 md:p-8">
      <div class="flex items-start gap-4">
        <div class="flex-shrink-0 w-16 h-16 bg-brand-accent/10 rounded-xl flex items-center justify-center">
          <svg class="w-8 h-8 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M3 21h18M3 21V9l9-7 9 7v12M9 21v-6h6v6" />
          </svg>
        </div>
        <div class="flex-1">
          <h1 class="text-2xl md:text-3xl font-bold text-brand-navy">{listing.title}</h1>
          <p class="text-brand-muted mt-1">{listing.category}</p>
          <div class="mt-2">
            <ReviewStars rating={listing.rating} reviews={listing.reviews} size="lg" />
          </div>
        </div>
      </div>

      <!-- Info Grid -->
      <div class="grid md:grid-cols-2 gap-6 mt-8">
        <div class="space-y-4">
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-brand-accent mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <div>
              <div class="text-sm font-medium text-brand-navy">Address</div>
              <div class="text-sm text-brand-muted">{listing.address}</div>
            </div>
          </div>

          {listing.phone && (
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-brand-accent mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              <div>
                <div class="text-sm font-medium text-brand-navy">Phone</div>
                <a href={`tel:${listing.phone}`} class="text-sm text-brand-accent hover:underline">{listing.phone}</a>
              </div>
            </div>
          )}

          {listing.url && (
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-brand-accent mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9" />
              </svg>
              <div>
                <div class="text-sm font-medium text-brand-navy">Website</div>
                <a href={listing.url} target="_blank" rel="noopener" class="text-sm text-brand-accent hover:underline">{listing.domain}</a>
              </div>
            </div>
          )}
        </div>

        <!-- Map -->
        <div class="rounded-xl overflow-hidden border border-slate-200" style="height: 250px;">
          <div id="listing-map" class="w-full h-full"></div>
        </div>
      </div>
    </div>

    <!-- Claim CTA -->
    <ClaimCTA businessName={listing.title} />

    <!-- Similar Roofers -->
    <div class="mt-8">
      <h2 class="text-xl font-bold text-brand-navy mb-4">
        Other Roofers in {listing.city}, {listing.state}
      </h2>
      <a href={`/states/${stateSlug}/${citySlug}/`} class="text-brand-accent hover:underline text-sm">
        View all roofers in {listing.city} &rarr;
      </a>
    </div>
  </div>

  <!-- Leaflet Map -->
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script define:vars={{ lat: listing.lat, lng: listing.lng, title: listing.title }}>
    const mapEl = document.getElementById('listing-map');
    if (mapEl && lat && lng) {
      const map = L.map(mapEl).setView([lat, lng], 14);
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; OpenStreetMap contributors',
        maxZoom: 18,
      }).addTo(map);

      const icon = L.divIcon({
        html: '<div style="background:#f59e0b;width:14px;height:14px;border-radius:50%;border:2px solid #0f172a;"></div>',
        iconSize: [14, 14],
        className: '',
      });

      L.marker([lat, lng], { icon }).addTo(map).bindPopup(`<strong>${title}</strong>`).openPopup();
    }
  </script>
</BaseLayout>
