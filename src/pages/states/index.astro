---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BreadcrumbNav from '../../components/BreadcrumbNav.astro';
import { getAllStates, getStateName } from '../../lib/data';

const states = getAllStates();
const totalListings = states.reduce((sum, s) => sum + s.count, 0);
---

<BaseLayout
  title="Browse Roofers by State | TopRoofers"
  description={`Find trusted roofing contractors across ${states.length} states. ${totalListings.toLocaleString()} verified roofers listed.`}
>
  <div class="max-w-7xl mx-auto px-4 py-8">
    <BreadcrumbNav crumbs={[
      { label: 'Home', href: '/' },
      { label: 'States', href: '/states/' },
    ]} />

    <h1 class="text-3xl font-bold text-brand-navy mb-2">Roofing Contractors by State</h1>
    <p class="text-brand-muted mb-8">{totalListings.toLocaleString()} verified roofers across {states.length} states</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {states.map(state => (
        <a
          href={`/states/${state.slug}/`}
          class="bg-white rounded-xl p-6 shadow-sm hover:shadow-md border border-slate-100 transition-all hover:-translate-y-0.5 group"
        >
          <div class="flex items-center justify-between">
            <div>
              <h2 class="text-lg font-semibold text-brand-navy group-hover:text-brand-accent transition">
                {getStateName(state.state)}
              </h2>
              <p class="text-sm text-brand-muted mt-1">
                {state.count} roofers in {state.cities.length} cities
              </p>
            </div>
            <div class="text-brand-accent">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M9 5l7 7-7 7" />
              </svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
