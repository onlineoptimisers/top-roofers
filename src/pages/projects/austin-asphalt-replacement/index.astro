---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { SITE } from '../../../data/site';

const title = 'Georgetown Asphalt Roof Replacement | Red Roan Construction';
const description = 'Full CertainTeed Landmark Pro replacement on a 3,100 sq ft Georgetown TX home. Completed in 2 days including upgraded ridge ventilation. Red Roan Construction.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: 'Georgetown Asphalt Roof Replacement',
  description: 'Full architectural shingle replacement on a 3,100 sq ft two-story home in Georgetown TX. CertainTeed Landmark Pro Weathered Wood with upgraded ridge ventilation.',
  locationCreated: {
    '@type': 'Place',
    name: 'Georgetown, TX',
  },
  dateCreated: '2025-02',
  creator: {
    '@type': 'RoofingContractor',
    name: SITE.name,
    telephone: SITE.phones.austinTel,
    url: SITE.url,
  },
};

const specs = [
  '3,100 sq ft two-story home',
  'CertainTeed Landmark Pro - Weathered Wood',
  'Synthetic underlayment',
  '4 ridge vents added (attic ventilation upgrade)',
  '6/12 walkable pitch',
  '2-day install',
  'Georgetown, TX - February 2025',
];
---

<BaseLayout title={title} description={description} schema={schema}>

  <!-- Hero -->
  <section class="bg-brand-navy text-white py-16 md:py-24 relative overflow-hidden">
    <div class="absolute inset-0 opacity-15">
      <img
        src="https://images.unsplash.com/photo-1767982008445-34182061f0b0?w=1600&q=60&auto=format&fit=crop"
        alt=""
        class="w-full h-full object-cover"
        loading="eager"
      />
    </div>
    <div class="absolute inset-0 bg-gradient-to-r from-brand-navy/90 to-brand-navy/60"></div>
    <div class="relative max-w-7xl mx-auto px-4">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-white/50 mb-6" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white transition">Home</a>
        <span>/</span>
        <a href="/projects/" class="hover:text-white transition">Projects</a>
        <span>/</span>
        <span class="text-white/80">Georgetown Asphalt Replacement</span>
      </nav>
      <p class="text-brand-accent font-semibold text-sm tracking-widest uppercase mb-3">Roof Replacement</p>
      <h1 class="text-4xl md:text-5xl font-extrabold leading-tight mb-4">Georgetown Asphalt Replacement</h1>
      <p class="text-white/70 text-lg max-w-2xl">
        3,100 sq ft architectural shingle replacement in Georgetown, TX. CertainTeed Landmark Pro with full ventilation upgrade. Two-day job, new homeowner moved in the following week.
      </p>
      <div class="mt-6 flex flex-wrap items-center gap-4 text-sm">
        <span class="flex items-center gap-1.5 text-white/60">
          <svg class="w-4 h-4 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>
          </svg>
          Georgetown, TX
        </span>
        <span class="flex items-center gap-1.5 text-white/60">
          <svg class="w-4 h-4 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/>
          </svg>
          February 2025
        </span>
        <span class="flex items-center gap-1.5 text-white/60">
          <svg class="w-4 h-4 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M3 21h18M3 21V9l9-7 9 7v12M9 21v-6h6v6"/>
          </svg>
          3,100 sq ft
        </span>
      </div>
    </div>
  </section>

  <!-- Project Detail -->
  <section class="py-16 md:py-24 bg-brand-light">
    <div class="max-w-7xl mx-auto px-4">

      <a href="/projects/" class="inline-flex items-center gap-2 text-brand-navy font-semibold text-sm mb-10 hover:text-brand-accent transition">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        Back to Projects
      </a>

      <div class="grid lg:grid-cols-5 gap-12 items-start">

        <!-- Left: image -->
        <div class="lg:col-span-3">
          <img
            src="https://images.unsplash.com/photo-1767982008445-34182061f0b0?w=800&q=80&auto=format&fit=crop"
            alt="CertainTeed Landmark Pro asphalt shingle replacement Georgetown TX"
            class="w-full h-80 md:h-[480px] object-cover rounded-xl shadow-md"
            loading="eager"
          />
          <!-- Secondary images -->
          <div class="grid grid-cols-2 gap-4 mt-4">
            <img
              src="https://images.unsplash.com/photo-1745478433432-0c65d929eacd?w=800&q=80&auto=format&fit=crop"
              alt="Ridge vent installation Georgetown TX roof"
              class="w-full h-44 object-cover rounded-lg"
              loading="lazy"
            />
            <img
              src="https://images.unsplash.com/photo-1761959245852-ffeba225c5c2?w=800&q=80&auto=format&fit=crop"
              alt="Roof underlayment prep two-story home"
              class="w-full h-44 object-cover rounded-lg"
              loading="lazy"
            />
          </div>
        </div>

        <!-- Right: story + specs -->
        <div class="lg:col-span-2 space-y-8">

          <!-- Story -->
          <div>
            <span class="inline-block bg-blue-100 text-blue-800 text-xs font-semibold px-2.5 py-1 rounded-full mb-4">Asphalt Shingle</span>
            <h2 class="text-2xl font-extrabold text-brand-navy mb-4">The Story</h2>
            <div class="space-y-4 text-slate-600 text-[15px] leading-relaxed">
              <p>
                Georgetown homeowner Connie M. bought a 15-year-old home and had it inspected by Red Roan before she even closed on the purchase. That inspection flagged two problems: delaminating shingles showing advanced granule loss and curling edges, and inadequate ridge ventilation causing significant heat buildup in the attic.
              </p>
              <p>
                Rather than move into a home with a roof already in failure, she booked the replacement before moving day. Smart call. Patching a delaminating roof on a freshly purchased house just delays the inevitable and raises the cost when it finally goes.
              </p>
              <p>
                We stripped the old roof down to the deck, replaced a few compromised sheets of plywood, and installed CertainTeed Landmark Pro architectural shingles in Weathered Wood. The 6/12 pitch kept the job walkable and efficient. We also added four ridge vents to correct the ventilation deficiency. In Central Texas summers, an overheated attic puts real pressure on HVAC and can shorten shingle life significantly.
              </p>
              <p>
                Total duration: two days. Connie moved in the following week on a roof that will not need to be touched for a generation.
              </p>
            </div>
          </div>

          <!-- Specs box -->
          <div class="bg-white rounded-xl border border-slate-100 shadow-sm p-6">
            <h3 class="text-lg font-bold text-brand-navy mb-4">Project Specs</h3>
            <ul class="space-y-0">
              {specs.map((spec) => (
                <li class="flex items-start gap-3 py-2.5 border-b border-slate-50 last:border-0">
                  <span class="mt-1.5 w-2.5 h-0.5 bg-brand-accent flex-shrink-0 inline-block rounded-full"></span>
                  <span class="text-slate-700 text-sm">{spec}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Result callout -->
          <div class="bg-brand-navy rounded-xl p-6 text-white">
            <p class="text-sm font-semibold text-brand-accent uppercase tracking-widest mb-2">Outcome</p>
            <p class="text-white/90 text-sm leading-relaxed">
              Clean replacement on a home entering new ownership. Ventilation corrected before occupancy. New homeowner moved in the following week with a full-lifetime-warranty roof over her head.
            </p>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-brand-warm py-16">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-extrabold text-brand-navy mb-4">Buying a Home? Protect Your Investment.</h2>
      <p class="text-slate-600 mb-8 text-lg">
        A pre-purchase roof inspection is the cheapest insurance you will ever buy. We document everything so you know exactly what you are inheriting before you sign.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact/" class="bg-brand-accent text-white px-8 py-3 rounded-lg font-semibold hover:opacity-90 transition">
          Book a Free Inspection
        </a>
        <a href={`tel:${SITE.phones.austinTel}`} class="border border-brand-navy/30 text-brand-navy px-8 py-3 rounded-lg font-semibold hover:bg-brand-navy hover:text-white transition">
          Call Austin: {SITE.phones.austin}
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
