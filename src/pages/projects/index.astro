---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE } from '../../data/site';

const title = 'Roofing Projects | Red Roan Construction';
const description = 'Browse completed roofing projects across the Texas Hill Country and Austin metro. Hail replacements, metal roofs, storm recovery, and commercial flat roofing.';

const projects = [
  {
    slug: '/projects/copperas-cove-hail-reroof/',
    title: 'Copperas Cove Hail Replacement',
    location: 'Copperas Cove, TX',
    type: 'Asphalt Shingle',
    typeColor: 'bg-blue-100 text-blue-800',
    description: 'Full 2,400 sq ft roof replacement after a Bell County hailstorm. Insurance claim handled start to finish — zero out-of-pocket for the homeowner.',
    img: 'https://images.unsplash.com/photo-1755168648692-ef8937b7e63e?w=800&q=80&auto=format&fit=crop',
    imgAlt: 'Roofing crew installing shingles on residential roof Copperas Cove TX',
  },
  {
    slug: '/projects/salado-metal-roof/',
    title: 'Salado Metal Roof Installation',
    location: 'Salado, TX',
    type: 'Metal Roofing',
    typeColor: 'bg-slate-100 text-slate-700',
    description: 'Standing seam Galvalume roof on a 1970s Hill Country ranch home. The homeowner was done patching — she invested in a 40-year solution instead.',
    img: 'https://images.unsplash.com/photo-1710139323182-69622cad5c3b?w=800&q=80&auto=format&fit=crop',
    imgAlt: 'Row of houses with brown shingle roofs Salado TX',
  },
  {
    slug: '/projects/hill-country-storm-recovery/',
    title: 'Lampasas Storm Recovery',
    location: 'Lampasas, TX',
    type: 'Storm Damage',
    typeColor: 'bg-amber-100 text-amber-800',
    description: 'Coordinated hail damage claim and replacement for a main house and detached garage. Both structures approved, same crew, completed back-to-back.',
    img: 'https://images.unsplash.com/photo-1635424709961-f3a150459ad4?w=800&q=80&auto=format&fit=crop',
    imgAlt: 'Two roofers working on residential roof Lampasas TX',
  },
  {
    slug: '/projects/austin-asphalt-replacement/',
    title: 'Georgetown Asphalt Replacement',
    location: 'Georgetown, TX',
    type: 'Asphalt Shingle',
    typeColor: 'bg-blue-100 text-blue-800',
    description: 'Full architectural shingle replacement on a Georgetown home, plus ventilation upgrade. New homeowner moved in the following week.',
    img: 'https://images.unsplash.com/photo-1767982008445-34182061f0b0?w=800&q=80&auto=format&fit=crop',
    imgAlt: 'Large American house with clear roof lines Georgetown TX',
  },
  {
    slug: '/projects/san-antonio-flat-commercial/',
    title: 'San Marcos Commercial Flat Roof',
    location: 'San Marcos, TX',
    type: 'Commercial',
    typeColor: 'bg-green-100 text-green-800',
    description: 'TPO flat roof replacement on a commercial building. Resolved chronic ponding, resealed 6 HVAC penetrations, 20-year membrane installed.',
    img: 'https://images.unsplash.com/photo-1755114203680-d39d95efa82c?w=800&q=80&auto=format&fit=crop',
    imgAlt: 'Aerial view of suburban house with grey roof San Marcos TX',
  },
];
---

<BaseLayout title={title} description={description}>

  <!-- Hero -->
  <section class="bg-brand-navy text-white py-16 md:py-24 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <img
        src="https://images.unsplash.com/photo-1745478433432-0c65d929eacd?w=1600&q=60&auto=format&fit=crop"
        alt=""
        class="w-full h-full object-cover"
      />
    </div>
    <div class="relative max-w-7xl mx-auto px-4">
      <p class="text-brand-accent font-semibold text-sm tracking-widest uppercase mb-3">Our Work</p>
      <h1 class="text-4xl md:text-5xl font-extrabold leading-tight mb-4">Roofing Projects</h1>
      <p class="text-white/70 text-lg max-w-2xl">
        Real jobs, real results. Browse completed projects across Central Texas - from hail replacements to full metal roof installs.
      </p>
    </div>
  </section>

  <!-- Project Grid -->
  <section class="py-16 md:py-24 bg-brand-light">
    <div class="max-w-7xl mx-auto px-4">

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {projects.map(project => (
          <article class="bg-white rounded-xl overflow-hidden shadow-sm border border-slate-100 hover:shadow-md transition group flex flex-col">
            <a href={project.slug} class="block overflow-hidden">
              <img
                src={project.img}
                alt={project.imgAlt}
                class="w-full h-52 object-cover group-hover:scale-105 transition duration-500"
                loading="lazy"
              />
            </a>
            <div class="p-6 flex flex-col flex-1">
              <div class="flex items-center gap-2 mb-3">
                <span class={`inline-block text-xs font-semibold px-2.5 py-1 rounded-full ${project.typeColor}`}>
                  {project.type}
                </span>
                <span class="text-xs text-slate-400 flex items-center gap-1">
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                    <circle cx="12" cy="10" r="3"/>
                  </svg>
                  {project.location}
                </span>
              </div>
              <h2 class="text-lg font-bold text-brand-navy mb-2 leading-snug">{project.title}</h2>
              <p class="text-slate-500 text-sm leading-relaxed flex-1">{project.description}</p>
              <a
                href={project.slug}
                class="mt-5 inline-flex items-center gap-1.5 text-brand-accent font-semibold text-sm hover:gap-2.5 transition-all"
              >
                View project
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          </article>
        ))}
      </div>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-brand-navy py-16 text-center">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="text-3xl font-extrabold text-white mb-4">Ready to Get Started?</h2>
      <p class="text-white/70 mb-8">Free inspection. No pressure. We document everything so you know exactly what you are dealing with before committing to anything.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact/" class="bg-brand-accent text-white px-8 py-3 rounded-lg font-semibold hover:opacity-90 transition">
          Request a Free Quote
        </a>
        <a href={`tel:${SITE.phones.hillCountryTel}`} class="border border-white/30 text-white px-8 py-3 rounded-lg font-semibold hover:bg-white/10 transition">
          Call {SITE.phones.hillCountry}
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
