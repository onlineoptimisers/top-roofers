---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import { SITE, SERVICES, TESTIMONIALS } from '../data/site';

const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": `${SITE.url}/#business`,
  "name": SITE.name,
  "description": SITE.description,
  "url": SITE.url,
  "telephone": [SITE.phones.hillCountryTel, SITE.phones.austinTel],
  "email": SITE.email,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": SITE.address.city,
    "addressRegion": SITE.address.state,
    "addressCountry": "US"
  },
  "areaServed": [
    "Copperas Cove, TX", "Lampasas, TX", "Burnet, TX", "Llano, TX",
    "Marble Falls, TX", "Fredericksburg, TX", "Georgetown, TX",
    "Cedar Park, TX", "Round Rock, TX", "Pflugerville, TX", "Kyle, TX", "Buda, TX"
  ],
  "knowsAbout": [
    "Roof Replacement", "Storm Damage Repair", "Roof Repair",
    "Roof Inspection", "Metal Roofing", "Asphalt Shingle Roofing"
  ],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Roofing Services",
    "itemListElement": SERVICES.map(s => ({
      "@type": "Offer",
      "itemOffered": {
        "@type": "Service",
        "name": s.title,
        "description": s.description
      }
    }))
  }
};

const projects = [
  {
    slug: 'copperas-cove-hail-reroof',
    title: 'Copperas Cove Hail Reroof',
    location: 'Copperas Cove, TX',
    type: 'Asphalt Shingle Replacement',
    detail: 'Full reroof after severe hail damage. Insurance claim handled end-to-end. Job completed in one day.',
  },
  {
    slug: 'salado-metal-roof',
    title: 'Salado Metal Roof',
    location: 'Salado, TX',
    type: 'Standing Seam Metal Roof',
    detail: 'New standing seam metal roof on a custom Hill Country home. 50-year lifespan, installed in three days.',
  },
  {
    slug: 'hill-country-storm-recovery',
    title: 'Hill Country Storm Recovery',
    location: 'Burnet County, TX',
    type: 'Storm Damage Repair',
    detail: 'Emergency tarping, full damage assessment, and reroof across three properties after a severe spring storm.',
  },
];

const faqs = [
  {
    q: 'Do you offer free inspections?',
    a: 'Yes. We provide free roof inspections for homeowners and buyers throughout the Hill Country and Austin metro. Our team documents every finding with photos so you have a complete record, whether for insurance, a home sale, or annual maintenance.',
  },
  {
    q: "What's covered by your workmanship warranty?",
    a: 'Our 5-year workmanship warranty covers any defects in installation or labor on every job we complete. If something fails because of how we installed it, we fix it at no cost. This is separate from any manufacturer warranty on your roofing materials.',
  },
  {
    q: 'Can you help with insurance claims after storm damage?',
    a: 'Absolutely. Storm damage claims are a large part of what we do in Central Texas. We work directly with your adjuster, document all damage thoroughly, and make sure nothing is missed. Most customers are surprised by how straightforward the process is when you have an experienced contractor guiding it.',
  },
  {
    q: 'How long does a roof replacement take?',
    a: 'Most residential roof replacements are completed in a single day. Larger homes, complex rooflines, or metal roofing projects typically take two to three days. We schedule every job with the goal of completing it efficiently and leaving your property clean before we leave.',
  },
];
---

<BaseLayout
  title="Red Roan Construction | Expert Roofing - Hill Country & Austin Metro"
  description={SITE.description}
  schema={schema}
>

  <!-- ===================== HERO ===================== -->
  <section class="relative bg-brand-navy overflow-hidden">
    <!-- Diagonal stripe texture -->
    <div
      class="absolute inset-0 opacity-[0.045]"
      style="background-image: repeating-linear-gradient(45deg, #ffffff 0, #ffffff 1px, transparent 0, transparent 50%); background-size: 20px 20px;"
    ></div>
    <!-- Radial gradient vignette -->
    <div class="absolute inset-0 bg-gradient-to-br from-[#111c33]/70 via-transparent to-brand-slate/30"></div>

    <div class="relative max-w-7xl mx-auto px-4 py-24 md:py-32 lg:py-40">
      <div class="max-w-3xl">
        <!-- Location badge -->
        <div class="inline-flex items-center gap-2 bg-brand-accent/20 border border-brand-accent/30 text-[#c2553d] rounded-full px-4 py-1.5 text-sm font-semibold mb-6">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          Texas Hill Country &amp; Austin Metro
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-6">
          Expert Roofing for the<br class="hidden sm:block" />
          <span class="text-brand-accent">Texas Hill Country</span><br class="hidden sm:block" />
          &amp; Austin Metro
        </h1>

        <p class="text-lg md:text-xl text-white/75 leading-relaxed mb-8 max-w-2xl">
          Asphalt shingle and metal roofing specialists. {SITE.years} years experience.
          {SITE.warranty}. Two dedicated service teams serving Central Texas.
        </p>

        <!-- Phone numbers -->
        <div class="flex flex-wrap gap-5 mb-10">
          <a
            href={`tel:${SITE.phones.hillCountryTel}`}
            class="flex items-center gap-2 text-white/80 hover:text-white transition-colors text-sm font-medium"
          >
            <span class="w-7 h-7 rounded-full bg-brand-accent/20 border border-brand-accent/40 flex items-center justify-center flex-shrink-0">
              <svg class="w-3.5 h-3.5 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </span>
            Hill Country: {SITE.phones.hillCountry}
          </a>
          <a
            href={`tel:${SITE.phones.austinTel}`}
            class="flex items-center gap-2 text-white/80 hover:text-white transition-colors text-sm font-medium"
          >
            <span class="w-7 h-7 rounded-full bg-brand-accent/20 border border-brand-accent/40 flex items-center justify-center flex-shrink-0">
              <svg class="w-3.5 h-3.5 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </span>
            Austin: {SITE.phones.austin}
          </a>
        </div>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-4">
          <a
            href="/contact/"
            class="inline-flex items-center gap-2 bg-brand-accent hover:bg-[#c2553d] text-white font-bold px-7 py-3.5 rounded-xl transition-colors duration-200 shadow-lg shadow-brand-accent/25"
          >
            Get a Free Quote
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </a>
          <a
            href="/projects/"
            class="inline-flex items-center gap-2 bg-white/10 hover:bg-white/20 border border-white/20 text-white font-semibold px-7 py-3.5 rounded-xl transition-colors duration-200"
          >
            See Our Work
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== TRUST BAR ===================== -->
  <section class="bg-[#111c33] text-white">
    <div class="max-w-7xl mx-auto px-4 py-5">
      <div class="grid grid-cols-2 md:grid-cols-4 divide-y md:divide-y-0 md:divide-x divide-white/10">
        {[
          { stat: '10+', label: 'Years Experience' },
          { stat: '5-Year', label: 'Workmanship Warranty' },
          { stat: '2 Teams', label: 'Serving Central Texas' },
          { stat: 'Hill Country & Austin', label: 'Two Dedicated Areas' },
        ].map(item => (
          <div class="flex flex-col items-center text-center py-4 md:px-6">
            <span class="text-2xl md:text-3xl font-extrabold text-brand-accent">{item.stat}</span>
            <span class="text-xs md:text-sm text-white/55 mt-1 font-medium">{item.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== SERVICES GRID ===================== -->
  <section class="bg-brand-warm py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-12">
        <p class="text-brand-accent font-semibold text-sm uppercase tracking-widest mb-3">What We Do</p>
        <h2 class="text-3xl md:text-4xl font-extrabold text-brand-navy">Our Roofing Services</h2>
        <p class="mt-4 text-brand-muted max-w-xl mx-auto leading-relaxed">
          From full replacements to emergency repairs, we handle every aspect of residential
          and light commercial roofing across Central Texas.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {SERVICES.map(service => (
          <ServiceCard
            slug={service.slug}
            title={service.title}
            description={service.description}
            icon={service.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== WHY RED ROAN ===================== -->
  <section class="bg-brand-light py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-12">
        <p class="text-brand-accent font-semibold text-sm uppercase tracking-widest mb-3">Why Choose Us</p>
        <h2 class="text-3xl md:text-4xl font-extrabold text-brand-navy">Built for Central Texas</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-8">

        <div class="bg-white rounded-2xl p-8 border border-slate-100 shadow-sm">
          <div class="w-12 h-12 rounded-xl bg-brand-accent/10 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-brand-navy mb-3">Local Texas Company</h3>
          <p class="text-brand-muted leading-relaxed text-sm">
            We have been roofing Hill Country and Central Texas homes for over 10 years. We know the
            local weather, the terrain, and what roofs here need to withstand. No out-of-state storm chasers.
          </p>
        </div>

        <div class="bg-white rounded-2xl p-8 border border-slate-100 shadow-sm">
          <div class="w-12 h-12 rounded-xl bg-brand-accent/10 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-brand-navy mb-3">5-Year Workmanship Warranty</h3>
          <p class="text-brand-muted leading-relaxed text-sm">
            Every job we complete is backed by a 5-year workmanship warranty. If it fails because of how
            we installed it, we fix it at no cost. No fine print, no runaround.
          </p>
        </div>

        <div class="bg-white rounded-2xl p-8 border border-slate-100 shadow-sm">
          <div class="w-12 h-12 rounded-xl bg-brand-accent/10 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-brand-navy mb-3">Two Dedicated Service Teams</h3>
          <p class="text-brand-muted leading-relaxed text-sm">
            Our Hill Country team runs out of Copperas Cove
            (<a href={`tel:${SITE.phones.hillCountryTel}`} class="text-brand-accent hover:underline font-medium">{SITE.phones.hillCountry}</a>).
            Our Austin team covers the metro
            (<a href={`tel:${SITE.phones.austinTel}`} class="text-brand-accent hover:underline font-medium">{SITE.phones.austin}</a>).
            Local response, no long wait times.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- ===================== PROJECTS TEASER ===================== -->
  <section class="bg-brand-warm py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-12">
        <p class="text-brand-accent font-semibold text-sm uppercase tracking-widest mb-3">Our Work</p>
        <h2 class="text-3xl md:text-4xl font-extrabold text-brand-navy">Recent Projects</h2>
        <p class="mt-4 text-brand-muted max-w-xl mx-auto leading-relaxed">
          Real jobs, real results. Here are a few recent projects from across our service area.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6 mb-10">
        {projects.map(project => (
          <a
            href={`/projects/${project.slug}/`}
            class="group bg-white rounded-2xl border border-slate-100 shadow-sm hover:shadow-md transition-shadow duration-200 overflow-hidden flex flex-col"
          >
            <!-- Placeholder image area -->
            <div class="bg-brand-navy/5 h-44 flex items-center justify-center border-b border-slate-100">
              <svg class="w-12 h-12 text-brand-navy/20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 21h18M3 21V9l9-7 9 7v12M9 21v-6h6v6" />
              </svg>
            </div>

            <div class="p-6 flex flex-col gap-2 flex-1">
              <span class="text-xs font-semibold text-brand-accent uppercase tracking-wide">{project.type}</span>
              <h3 class="text-lg font-bold text-brand-navy leading-snug">{project.title}</h3>
              <p class="text-sm text-brand-muted leading-relaxed flex-1">{project.detail}</p>
              <div class="flex items-center justify-between mt-3 pt-3 border-t border-slate-100">
                <span class="text-xs text-brand-muted flex items-center gap-1">
                  <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  </svg>
                  {project.location}
                </span>
                <span class="text-xs font-semibold text-brand-accent group-hover:underline">View project &rarr;</span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div class="text-center">
        <a
          href="/projects/"
          class="inline-flex items-center gap-2 text-brand-navy font-semibold hover:text-brand-accent transition-colors text-sm"
        >
          View all projects
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ===================== TESTIMONIALS ===================== -->
  <section class="bg-brand-navy py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-12">
        <p class="text-brand-accent font-semibold text-sm uppercase tracking-widest mb-3">Customer Reviews</p>
        <h2 class="text-3xl md:text-4xl font-extrabold text-white">What Our Customers Say</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {TESTIMONIALS.slice(0, 3).map(t => (
          <div class="bg-white/5 border border-white/10 rounded-2xl p-7 flex flex-col gap-4">
            <!-- Stars -->
            <div class="flex gap-0.5">
              {Array.from({ length: t.stars }).map(() => (
                <svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <!-- Quote -->
            <blockquote class="text-white/80 text-sm leading-relaxed flex-1">
              "{t.text}"
            </blockquote>
            <!-- Attribution -->
            <div class="border-t border-white/10 pt-4">
              <p class="font-semibold text-white text-sm">{t.name}</p>
              <p class="text-white/50 text-xs">{t.location}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== SERVICE AREA ===================== -->
  <section class="bg-brand-light py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-12">
        <p class="text-brand-accent font-semibold text-sm uppercase tracking-widest mb-3">Where We Work</p>
        <h2 class="text-3xl md:text-4xl font-extrabold text-brand-navy">Service Areas</h2>
        <p class="mt-4 text-brand-muted max-w-xl mx-auto leading-relaxed">
          Two teams, one mission: fast, quality roofing across Central Texas.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto mb-12">

        <!-- Hill Country Team -->
        <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-8">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 rounded-lg bg-brand-accent/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 21h18M3 21V9l9-7 9 7v12M9 21v-6h6v6" />
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-brand-navy">Hill Country Team</h3>
              <a href={`tel:${SITE.phones.hillCountryTel}`} class="text-sm text-brand-accent font-semibold hover:underline">
                {SITE.phones.hillCountry}
              </a>
            </div>
          </div>
          <ul class="grid grid-cols-2 gap-y-2.5 gap-x-4">
            {['Copperas Cove', 'Lampasas', 'Burnet', 'Llano', 'Marble Falls', 'Fredericksburg'].map(area => (
              <li class="flex items-center gap-2 text-sm text-brand-muted">
                <svg class="w-3.5 h-3.5 text-brand-accent flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                {area}
              </li>
            ))}
          </ul>
        </div>

        <!-- Austin Team -->
        <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-8">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 rounded-lg bg-brand-accent/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-brand-navy">Austin Team</h3>
              <a href={`tel:${SITE.phones.austinTel}`} class="text-sm text-brand-accent font-semibold hover:underline">
                {SITE.phones.austin}
              </a>
            </div>
          </div>
          <ul class="grid grid-cols-2 gap-y-2.5 gap-x-4">
            {['Georgetown', 'Cedar Park', 'Round Rock', 'Pflugerville', 'Kyle', 'Buda'].map(area => (
              <li class="flex items-center gap-2 text-sm text-brand-muted">
                <svg class="w-3.5 h-3.5 text-brand-accent flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                {area}
              </li>
            ))}
          </ul>
        </div>

      </div>

      <div class="text-center">
        <a
          href="/contact/"
          class="inline-flex items-center gap-2 bg-brand-accent hover:bg-[#c2553d] text-white font-bold px-8 py-4 rounded-xl transition-colors duration-200 shadow-lg shadow-brand-accent/20"
        >
          Get a Free Quote
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ===================== FAQ ===================== -->
  <section class="bg-brand-warm py-20 md:py-28">
    <div class="max-w-3xl mx-auto px-4">
      <div class="text-center mb-12">
        <p class="text-brand-accent font-semibold text-sm uppercase tracking-widest mb-3">FAQ</p>
        <h2 class="text-3xl md:text-4xl font-extrabold text-brand-navy">Common Questions</h2>
      </div>

      <div class="space-y-3">
        {faqs.map(faq => (
          <details class="group bg-white rounded-xl border border-slate-100 shadow-sm overflow-hidden">
            <summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer list-none font-semibold text-brand-navy text-sm md:text-base select-none hover:text-brand-accent transition-colors">
              {faq.q}
              <svg
                class="w-5 h-5 text-brand-accent flex-shrink-0 transition-transform duration-200 group-open:rotate-180"
                fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-6 pt-1 text-sm text-brand-muted leading-relaxed border-t border-slate-100">
              {faq.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== FINAL CTA BANNER ===================== -->
  <section class="bg-brand-accent py-20 md:py-28">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-extrabold text-white mb-4">
        Ready to get started?
      </h2>
      <p class="text-white/80 text-lg mb-10 max-w-xl mx-auto leading-relaxed">
        Call your nearest team or send us a message. Free inspections available throughout
        Hill Country and the Austin metro.
      </p>

      <!-- Phone CTAs -->
      <div class="flex flex-wrap justify-center gap-4 mb-6">
        <a
          href={`tel:${SITE.phones.hillCountryTel}`}
          class="inline-flex items-center gap-3 bg-white text-brand-accent font-bold px-6 py-3.5 rounded-xl hover:bg-brand-light transition-colors shadow-lg"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Hill Country: {SITE.phones.hillCountry}
        </a>
        <a
          href={`tel:${SITE.phones.austinTel}`}
          class="inline-flex items-center gap-3 bg-white text-brand-accent font-bold px-6 py-3.5 rounded-xl hover:bg-brand-light transition-colors shadow-lg"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Austin: {SITE.phones.austin}
        </a>
      </div>

      <!-- Contact form link -->
      <a
        href="/contact/"
        class="inline-flex items-center gap-2 bg-white/15 hover:bg-white/25 border border-white/30 text-white font-semibold px-7 py-3.5 rounded-xl transition-colors duration-200"
      >
        Send us a message
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </section>

</BaseLayout>
