---
import BaseLayout from '../layouts/BaseLayout.astro';
import ListingCard from '../components/ListingCard.astro';
import { getAllStates, getAllCities, getAllListings, getStateName } from '../lib/data';
import { BLOG_POSTS } from '../lib/blog';
import { SERVICES } from '../lib/services';

const states = getAllStates();
const cities = getAllCities().slice(0, 12);
const allListings = getAllListings();
const totalListings = allListings.length;
const totalCities = getAllCities().length;
const topListings = [...allListings].sort((a, b) => b.reviews - a.reviews || b.rating - a.rating).slice(0, 6);

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'TopRoofers',
  url: 'https://top-roofers.pages.dev',
  description: 'Find trusted, verified roofing contractors near you.',
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://top-roofers.pages.dev/states/?q={search_term}',
    'query-input': 'required name=search_term',
  },
};
---

<BaseLayout title="TopRoofers - Find Trusted Roofing Contractors Near You" schema={schema}>
  <!-- Hero -->
  <section class="bg-brand-navy text-white py-20 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2260%22 height=%2260%22><path d=%22M30 0L60 30L30 60L0 30Z%22 fill=%22none%22 stroke=%22white%22 stroke-width=%220.5%22/></svg>'); background-size: 60px 60px;"></div>
    </div>
    <div class="max-w-7xl mx-auto px-4 text-center relative z-10">
      <h1 class="text-4xl md:text-5xl font-['Merriweather',serif] font-bold mb-4">
        Find Trusted <span class="text-brand-accent">Roofers</span> Near You
      </h1>
      <p class="text-lg text-slate-300 max-w-2xl mx-auto mb-8">
        Browse {totalListings.toLocaleString()} verified roofing contractors across {totalCities} cities. Real reviews, real ratings, real businesses.
      </p>

      <!-- Search box -->
      <div class="max-w-lg mx-auto">
        <div class="flex bg-white rounded-xl shadow-xl overflow-hidden">
          <input
            type="text"
            id="city-search"
            placeholder="Enter your city..."
            class="flex-1 px-5 py-4 text-brand-navy text-lg outline-none"
          />
          <button id="search-btn" class="bg-brand-accent text-brand-navy px-6 font-semibold hover:bg-brand-accent-light transition">
            Search
          </button>
        </div>
      </div>

      <!-- Stats row -->
      <div class="flex justify-center gap-8 mt-10 text-center">
        <div>
          <div class="text-3xl font-bold text-brand-accent">{totalListings.toLocaleString()}</div>
          <div class="text-sm text-slate-400">Roofers Listed</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-brand-accent">{totalCities}</div>
          <div class="text-sm text-slate-400">Cities Covered</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-brand-accent">{states.length}</div>
          <div class="text-sm text-slate-400">States</div>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-brand-navy text-center mb-12">How It Works</h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-14 h-14 bg-brand-accent/10 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </div>
          <h3 class="font-semibold text-brand-navy text-lg mb-2">1. Search Your City</h3>
          <p class="text-sm text-brand-muted">Enter your city to find every verified roofing contractor in your area, complete with ratings and reviews.</p>
        </div>
        <div class="text-center">
          <div class="w-14 h-14 bg-brand-accent/10 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
            </svg>
          </div>
          <h3 class="font-semibold text-brand-navy text-lg mb-2">2. Compare Roofers</h3>
          <p class="text-sm text-brand-muted">See real Google ratings, review counts, and contact details side by side. No paid placements in the default sort.</p>
        </div>
        <div class="text-center">
          <div class="w-14 h-14 bg-brand-accent/10 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <h3 class="font-semibold text-brand-navy text-lg mb-2">3. Contact Directly</h3>
          <p class="text-sm text-brand-muted">Call, visit their website, or request a quote. We connect you directly with the contractor, no middleman.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Top Rated Roofers -->
  <section class="py-16 max-w-7xl mx-auto px-4">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl font-bold text-brand-navy">Top Rated Roofers</h2>
      <a href="/states/" class="text-sm text-brand-accent hover:underline">View all &rarr;</a>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
      {topListings.map(listing => {
        const stateSlug = listing.state === 'TX' ? 'texas' : listing.state === 'FL' ? 'florida' : 'north-carolina';
        const citySlug = listing.city.toLowerCase().replace(/[^a-z0-9]+/g, '-');
        return (
          <a href={`/states/${stateSlug}/${citySlug}/${listing.slug}/`} class="bg-white rounded-xl shadow-sm hover:shadow-md border border-slate-100 p-5 transition-all hover:-translate-y-0.5 group">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 bg-brand-accent/10 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M3 21h18M3 21V9l9-7 9 7v12M9 21v-6h6v6" />
                </svg>
              </div>
              <div class="min-w-0">
                <h3 class="font-semibold text-brand-navy group-hover:text-brand-accent transition truncate">{listing.title}</h3>
                <p class="text-xs text-brand-muted">{listing.city}, {listing.state}</p>
              </div>
            </div>
            <div class="flex items-center gap-1">
              {Array.from({ length: 5 }).map((_, i) => (
                <svg class={`w-4 h-4 ${i < Math.floor(listing.rating) ? 'text-brand-star' : 'text-slate-200'}`} fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
              <span class="text-sm font-semibold text-brand-navy ml-1">{listing.rating}</span>
              <span class="text-xs text-brand-muted">({listing.reviews} reviews)</span>
            </div>
            <p class="text-xs text-brand-muted mt-2 truncate">{listing.address}</p>
          </a>
        );
      })}
    </div>
  </section>

  <!-- Trust Signals Banner -->
  <section class="py-12 bg-slate-50 border-y border-slate-200">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div>
          <div class="text-2xl font-bold text-brand-navy">{totalListings.toLocaleString()}+</div>
          <div class="text-xs text-brand-muted mt-1">Verified Contractors</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-brand-navy">{totalCities}+</div>
          <div class="text-xs text-brand-muted mt-1">US Cities</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-brand-navy">Monthly</div>
          <div class="text-xs text-brand-muted mt-1">Data Updates</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-brand-navy">100%</div>
          <div class="text-xs text-brand-muted mt-1">Real Reviews</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Cities -->
  <section class="py-16 max-w-7xl mx-auto px-4">
    <h2 class="text-2xl font-bold text-brand-navy mb-8">Browse by City</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
      {cities.map(city => (
        <a
          href={`/states/${city.stateSlug}/${city.slug}/`}
          class="bg-white rounded-xl p-5 shadow-sm hover:shadow-md border border-slate-100 transition-all hover:-translate-y-0.5 group"
        >
          <h3 class="font-semibold text-brand-navy group-hover:text-brand-accent transition">
            {city.city}, {city.state}
          </h3>
          <p class="text-sm text-brand-muted mt-1">
            {city.count} roofers &middot; {city.avgRating.toFixed(1)} avg rating
          </p>
        </a>
      ))}
    </div>
  </section>

  <!-- Browse by State -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-brand-navy mb-8">Browse by State</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-3">
        {states.map(state => (
          <a
            href={`/states/${state.slug}/`}
            class="text-center py-3 px-4 rounded-lg border border-slate-200 hover:border-brand-accent hover:bg-brand-accent/5 transition group"
          >
            <div class="font-semibold text-brand-navy group-hover:text-brand-accent">{getStateName(state.state)}</div>
            <div class="text-xs text-brand-muted">{state.count} roofers</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Value Prop / For Roofers -->
  <section class="py-16 max-w-7xl mx-auto px-4">
    <div class="bg-gradient-to-r from-brand-navy to-brand-dark rounded-2xl p-8 md:p-12 text-white">
      <div class="grid md:grid-cols-2 gap-8 items-center">
        <div>
          <h2 class="text-2xl font-bold mb-4">Are You a Roofing Contractor?</h2>
          <p class="text-slate-300 mb-6">
            Your business is already listed on TopRoofers with a dofollow backlink to your website. Claim your listing to update your information, add photos, and stand out from the competition.
          </p>
          <ul class="space-y-3 text-sm">
            <li class="flex items-center gap-2">
              <svg class="w-5 h-5 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7" /></svg>
              Dofollow backlink to your website (real SEO value)
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-5 h-5 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7" /></svg>
              Update your services, hours, and contact info
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-5 h-5 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7" /></svg>
              Get priority placement in your city
            </li>
          </ul>
          <a href="/claim/" class="inline-block mt-6 bg-brand-accent text-brand-navy px-6 py-3 rounded-lg font-semibold hover:bg-brand-accent-light transition">
            Claim Your Listing
          </a>
        </div>
        <div class="hidden md:flex justify-center">
          <svg class="w-48 h-48 text-brand-accent/20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="0.5">
            <path d="M3 21h18M3 21V9l9-7 9 7v12M9 21v-6h6v6" />
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- Roofing Services -->
  <section class="py-16 max-w-7xl mx-auto px-4">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl font-bold text-brand-navy">Roofing Services</h2>
      <a href="/services/" class="text-sm text-brand-accent hover:underline">View all &rarr;</a>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {SERVICES.slice(0, 4).map(service => (
        <a href={`/services/${service.slug}/`} class="bg-white rounded-xl shadow-sm hover:shadow-md border border-slate-100 p-5 transition-all hover:-translate-y-0.5 group text-center">
          <h3 class="font-semibold text-brand-navy group-hover:text-brand-accent transition">{service.shortTitle}</h3>
          <p class="text-xs text-brand-muted mt-1">{service.avgCost}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- Blog / Guides -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold text-brand-navy">Roofing Guides</h2>
        <a href="/blog/" class="text-sm text-brand-accent hover:underline">View all articles &rarr;</a>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {BLOG_POSTS.slice(0, 3).map(post => (
          <a href={`/blog/${post.slug}/`} class="bg-brand-light rounded-xl border border-slate-200 p-5 hover:border-brand-accent transition-all hover:-translate-y-0.5 group">
            <span class="text-xs bg-brand-accent/10 text-brand-accent px-2 py-1 rounded font-medium">{post.category}</span>
            <h3 class="font-semibold text-brand-navy group-hover:text-brand-accent transition mt-3 mb-2">{post.title}</h3>
            <p class="text-xs text-brand-muted">{post.description}</p>
            <span class="text-xs text-brand-accent mt-3 block">Read guide &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Cost Estimator CTA -->
  <section class="py-12 max-w-7xl mx-auto px-4">
    <a href="/tools/cost-estimator/" class="block bg-gradient-to-r from-brand-accent to-amber-400 rounded-2xl p-8 hover:shadow-lg transition group">
      <div class="flex items-center justify-between">
        <div>
          <h2 class="text-2xl font-bold text-brand-navy mb-2">Roof Cost Estimator</h2>
          <p class="text-brand-navy/70">Get an instant estimate by material, size, and location. Interactive calculator with 2026 pricing.</p>
        </div>
        <svg class="w-10 h-10 text-brand-navy/50 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </div>
    </a>
  </section>

  <!-- FAQ Section -->
  <section class="py-16 max-w-3xl mx-auto px-4">
    <h2 class="text-2xl font-bold text-brand-navy text-center mb-10">Frequently Asked Questions</h2>
    <div class="space-y-4">
      <details class="bg-white rounded-xl border border-slate-200 overflow-hidden group" open>
        <summary class="px-6 py-4 cursor-pointer font-semibold text-brand-navy hover:text-brand-accent transition flex items-center justify-between">
          How are roofers listed on TopRoofers?
          <svg class="w-5 h-5 text-brand-muted group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7" /></svg>
        </summary>
        <div class="px-6 pb-4 text-sm text-brand-muted">
          We pull data directly from Google Maps and verify that each business has a real website, a physical address, and customer reviews. Listings are sorted by rating and review count by default, not by who pays the most.
        </div>
      </details>
      <details class="bg-white rounded-xl border border-slate-200 overflow-hidden group">
        <summary class="px-6 py-4 cursor-pointer font-semibold text-brand-navy hover:text-brand-accent transition flex items-center justify-between">
          Is it really no cost to be listed?
          <svg class="w-5 h-5 text-brand-muted group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7" /></svg>
        </summary>
        <div class="px-6 pb-4 text-sm text-brand-muted">
          Yes. Every roofing contractor with a Google Business listing is included at no cost. Claiming your listing is also no cost. Featured placement is available as an optional upgrade.
        </div>
      </details>
      <details class="bg-white rounded-xl border border-slate-200 overflow-hidden group">
        <summary class="px-6 py-4 cursor-pointer font-semibold text-brand-navy hover:text-brand-accent transition flex items-center justify-between">
          What is a dofollow backlink and why does it matter?
          <svg class="w-5 h-5 text-brand-muted group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7" /></svg>
        </summary>
        <div class="px-6 pb-4 text-sm text-brand-muted">
          A dofollow backlink tells Google that TopRoofers is vouching for your website. This passes authority to your site and can help it show up higher in search results. Most large directories (like Yelp) use nofollow links, which pass no value. Ours are dofollow.
        </div>
      </details>
      <details class="bg-white rounded-xl border border-slate-200 overflow-hidden group">
        <summary class="px-6 py-4 cursor-pointer font-semibold text-brand-navy hover:text-brand-accent transition flex items-center justify-between">
          How often is the data updated?
          <svg class="w-5 h-5 text-brand-muted group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7" /></svg>
        </summary>
        <div class="px-6 pb-4 text-sm text-brand-muted">
          We refresh all listing data monthly from Google Maps. Ratings, review counts, and business details are updated automatically. If you claim your listing, you can update your information at any time.
        </div>
      </details>
      <details class="bg-white rounded-xl border border-slate-200 overflow-hidden group">
        <summary class="px-6 py-4 cursor-pointer font-semibold text-brand-navy hover:text-brand-accent transition flex items-center justify-between">
          How do I remove my business from this directory?
          <svg class="w-5 h-5 text-brand-muted group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7" /></svg>
        </summary>
        <div class="px-6 pb-4 text-sm text-brand-muted">
          Contact us and we will remove your listing within 24 hours. No questions asked.
        </div>
      </details>
    </div>
  </section>

  <script>
    const input = document.getElementById('city-search') as HTMLInputElement;
    const btn = document.getElementById('search-btn');

    function doSearch() {
      const q = input?.value.trim().toLowerCase();
      if (q) window.location.href = `/states/?q=${encodeURIComponent(q)}`;
    }

    btn?.addEventListener('click', doSearch);
    input?.addEventListener('keydown', (e) => { if (e.key === 'Enter') doSearch(); });
  </script>
</BaseLayout>
