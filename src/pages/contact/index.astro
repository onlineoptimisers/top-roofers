---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE } from '../../data/site';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `${SITE.url}/#business`,
  name: SITE.name,
  url: SITE.url,
  email: SITE.email,
  telephone: SITE.phones.hillCountry,
  additionalProperty: [
    {
      '@type': 'PropertyValue',
      name: 'Hill Country Phone',
      value: SITE.phones.hillCountry,
    },
    {
      '@type': 'PropertyValue',
      name: 'Austin Metro Phone',
      value: SITE.phones.austin,
    },
  ],
  address: {
    '@type': 'PostalAddress',
    addressLocality: SITE.address.city,
    addressRegion: SITE.address.state,
    addressCountry: 'US',
  },
  areaServed: [
    { '@type': 'AdministrativeArea', name: 'Texas Hill Country' },
    { '@type': 'AdministrativeArea', name: 'Austin Metro, Texas' },
  ],
  priceRange: '$$',
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
    opens: '08:00',
    closes: '17:00',
  },
};
---

<BaseLayout
  title={`Contact ${SITE.name} | Free Roofing Estimate`}
  description={`Get a free roofing estimate from ${SITE.name}. Hill Country: ${SITE.phones.hillCountry}. Austin Metro: ${SITE.phones.austin}. We respond within 1 business day.`}
  schema={schema}
  canonical={`${SITE.url}/contact/`}
>

  <!-- Hero -->
  <section class="bg-brand-navy text-white py-20 relative overflow-hidden">
    <div class="absolute inset-0 opacity-5"
      style="background-image: url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2260%22 height=%2260%22><path d=%22M30 0L60 30L30 60L0 30Z%22 fill=%22none%22 stroke=%22white%22 stroke-width=%221%22/></svg>'); background-size: 60px 60px;">
    </div>
    <div class="max-w-4xl mx-auto px-4 text-center relative z-10">
      <p class="text-brand-accent font-semibold text-sm uppercase tracking-widest mb-3">No Obligation</p>
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Get a Free Roofing Estimate</h1>
      <p class="text-lg text-white/70 max-w-2xl mx-auto">
        Call the team closest to you or fill out the form below. We respond within 1 business day and schedule a free on-site inspection.
      </p>
    </div>
  </section>

  <!-- Contact Cards + Form -->
  <section class="py-20 bg-brand-light">
    <div class="max-w-5xl mx-auto px-4">

      <!-- Two contact cards -->
      <div class="grid md:grid-cols-2 gap-6 mb-14">

        <!-- Hill Country -->
        <div class="bg-white rounded-2xl p-8 shadow-sm border border-slate-100">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-brand-accent/10 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <p class="text-xs text-brand-muted uppercase tracking-widest font-medium">Hill Country Team</p>
              <h2 class="font-bold text-brand-navy text-lg">Central &amp; West Texas</h2>
            </div>
          </div>
          <a
            href={`tel:${SITE.phones.hillCountryTel}`}
            class="flex items-center gap-3 text-brand-navy font-bold text-2xl hover:text-brand-accent transition mb-3"
          >
            <svg class="w-5 h-5 text-brand-accent flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            {SITE.phones.hillCountry}
          </a>
          <p class="text-sm text-brand-muted">
            Serving Copperas Cove, Lampasas, Burnet &amp; surrounding areas
          </p>
        </div>

        <!-- Austin -->
        <div class="bg-white rounded-2xl p-8 shadow-sm border border-slate-100">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-brand-accent/10 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
            </div>
            <div>
              <p class="text-xs text-brand-muted uppercase tracking-widest font-medium">Austin Team</p>
              <h2 class="font-bold text-brand-navy text-lg">Austin Metro Region</h2>
            </div>
          </div>
          <a
            href={`tel:${SITE.phones.austinTel}`}
            class="flex items-center gap-3 text-brand-navy font-bold text-2xl hover:text-brand-accent transition mb-3"
          >
            <svg class="w-5 h-5 text-brand-accent flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            {SITE.phones.austin}
          </a>
          <p class="text-sm text-brand-muted">
            Serving Georgetown, Cedar Park, Round Rock &amp; surrounding areas
          </p>
        </div>

      </div>

      <!-- Shared email -->
      <div class="flex justify-center mb-14">
        <a
          href={`mailto:${SITE.email}`}
          class="inline-flex items-center gap-3 bg-white rounded-xl px-6 py-4 shadow-sm border border-slate-100 text-brand-navy font-semibold hover:text-brand-accent transition"
        >
          <svg class="w-5 h-5 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          {SITE.email}
        </a>
      </div>

      <!-- Quote Form -->
      <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="bg-brand-navy px-8 py-6">
          <h2 class="text-white font-bold text-2xl">Request a Free Estimate</h2>
          <p class="text-white/60 text-sm mt-1">Fill in the details below and we'll be in touch within 1 business day.</p>
        </div>
        <form action="#" method="post" class="p-8 space-y-6">

          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <label for="name" class="block text-sm font-semibold text-brand-navy mb-2">
                Your Name <span class="text-brand-accent">*</span>
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                placeholder="Jane Smith"
                class="w-full rounded-xl border border-slate-200 px-4 py-3 text-brand-navy placeholder:text-slate-400 focus:outline-none focus:border-brand-accent focus:ring-2 focus:ring-brand-accent/20 transition"
              />
            </div>
            <div>
              <label for="phone" class="block text-sm font-semibold text-brand-navy mb-2">
                Phone Number <span class="text-brand-accent">*</span>
              </label>
              <input
                type="tel"
                id="phone"
                name="phone"
                required
                placeholder="(512) 555-0100"
                class="w-full rounded-xl border border-slate-200 px-4 py-3 text-brand-navy placeholder:text-slate-400 focus:outline-none focus:border-brand-accent focus:ring-2 focus:ring-brand-accent/20 transition"
              />
            </div>
          </div>

          <div>
            <label for="email" class="block text-sm font-semibold text-brand-navy mb-2">Email Address</label>
            <input
              type="email"
              id="email"
              name="email"
              placeholder="jane@example.com"
              class="w-full rounded-xl border border-slate-200 px-4 py-3 text-brand-navy placeholder:text-slate-400 focus:outline-none focus:border-brand-accent focus:ring-2 focus:ring-brand-accent/20 transition"
            />
          </div>

          <div>
            <label for="service" class="block text-sm font-semibold text-brand-navy mb-2">
              What do you need?
            </label>
            <select
              id="service"
              name="service"
              class="w-full rounded-xl border border-slate-200 px-4 py-3 text-brand-navy bg-white focus:outline-none focus:border-brand-accent focus:ring-2 focus:ring-brand-accent/20 transition"
            >
              <option value="">Select a service...</option>
              <option value="roof-replacement">Roof Replacement</option>
              <option value="storm-damage">Storm Damage</option>
              <option value="roof-repair">Roof Repair</option>
              <option value="inspection">Inspection</option>
              <option value="not-sure">Not sure yet</option>
            </select>
          </div>

          <div>
            <label for="referral" class="block text-sm font-semibold text-brand-navy mb-2">
              How did you hear about us? <span class="text-brand-muted font-normal">(optional)</span>
            </label>
            <input
              type="text"
              id="referral"
              name="referral"
              placeholder="Google, neighbour, Facebook..."
              class="w-full rounded-xl border border-slate-200 px-4 py-3 text-brand-navy placeholder:text-slate-400 focus:outline-none focus:border-brand-accent focus:ring-2 focus:ring-brand-accent/20 transition"
            />
          </div>

          <div>
            <label for="message" class="block text-sm font-semibold text-brand-navy mb-2">
              Tell us about your project <span class="text-brand-muted font-normal">(optional)</span>
            </label>
            <textarea
              id="message"
              name="message"
              rows="4"
              placeholder="Describe what's happening with your roof, your address, or any details that will help us prepare..."
              class="w-full rounded-xl border border-slate-200 px-4 py-3 text-brand-navy placeholder:text-slate-400 focus:outline-none focus:border-brand-accent focus:ring-2 focus:ring-brand-accent/20 transition resize-none"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full bg-brand-accent text-white py-4 rounded-xl font-bold text-lg hover:bg-brand-accent-light transition focus:outline-none focus:ring-4 focus:ring-brand-accent/30"
          >
            Request Free Estimate
          </button>

          <p class="text-xs text-brand-muted text-center">
            We will never share your information. No spam, no third-party calls.
          </p>
        </form>
      </div>

    </div>
  </section>

  <!-- What to Expect -->
  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <div class="text-center mb-12">
        <p class="text-brand-accent font-semibold text-sm uppercase tracking-widest mb-3">What Happens Next</p>
        <h2 class="text-3xl font-bold text-brand-navy">Three Simple Steps</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8">

        <div class="text-center">
          <div class="w-16 h-16 bg-brand-accent rounded-2xl flex items-center justify-center mx-auto mb-5 shadow-lg shadow-brand-accent/30">
            <svg class="w-8 h-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <div class="text-xs text-brand-muted uppercase tracking-widest font-semibold mb-2">Step 1</div>
          <h3 class="font-bold text-brand-navy text-lg mb-2">We Call You Within 1 Business Day</h3>
          <p class="text-sm text-brand-muted leading-relaxed">
            A real person from the team covering your area will call to confirm your details and answer any initial questions.
          </p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 bg-brand-navy rounded-2xl flex items-center justify-center mx-auto mb-5 shadow-lg shadow-brand-navy/30">
            <svg class="w-8 h-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <div class="text-xs text-brand-muted uppercase tracking-widest font-semibold mb-2">Step 2</div>
          <h3 class="font-bold text-brand-navy text-lg mb-2">We Schedule a Free Inspection</h3>
          <p class="text-sm text-brand-muted leading-relaxed">
            We come to you at a time that suits. We inspect the roof, document any issues, and take photos you can keep.
          </p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 bg-brand-accent/10 rounded-2xl flex items-center justify-center mx-auto mb-5 border-2 border-brand-accent/20">
            <svg class="w-8 h-8 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <div class="text-xs text-brand-muted uppercase tracking-widest font-semibold mb-2">Step 3</div>
          <h3 class="font-bold text-brand-navy text-lg mb-2">You Receive a Written Estimate</h3>
          <p class="text-sm text-brand-muted leading-relaxed">
            A clear, itemised written estimate with no hidden fees. You decide if and when you want to proceed. Zero pressure.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- Warranty callout strip -->
  <section class="py-10 bg-brand-warm border-y border-slate-200">
    <div class="max-w-4xl mx-auto px-4 flex flex-col md:flex-row items-center justify-between gap-6 text-center md:text-left">
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 bg-brand-accent/10 rounded-xl flex items-center justify-center flex-shrink-0">
          <svg class="w-6 h-6 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
        </div>
        <div>
          <p class="font-bold text-brand-navy">5-Year Workmanship Warranty</p>
          <p class="text-sm text-brand-muted">Every installation backed by our written guarantee.</p>
        </div>
      </div>
      <a
        href="/about/"
        class="text-sm text-brand-accent font-semibold hover:underline flex-shrink-0"
      >
        Learn more about our warranty &rarr;
      </a>
    </div>
  </section>

</BaseLayout>
