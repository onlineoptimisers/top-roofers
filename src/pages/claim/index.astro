---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BreadcrumbNav from '../../components/BreadcrumbNav.astro';
---

<BaseLayout
  title="Claim Your Listing | TopRoofers"
  description="Claim your roofing business listing on TopRoofers. Update your information, add photos, and get a dofollow backlink to your website."
>
  <div class="max-w-3xl mx-auto px-4 py-8">
    <BreadcrumbNav crumbs={[
      { label: 'Home', href: '/' },
      { label: 'Claim Your Listing', href: '/claim/' },
    ]} />

    <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-8 md:p-10">
      <h1 class="text-3xl font-bold text-brand-navy mb-2">Claim Your Listing</h1>
      <p class="text-brand-muted mb-8">
        Your roofing business is already listed on TopRoofers. Claim it to take control of your profile, update your information, and get a dofollow backlink to your website.
      </p>

      <!-- Benefits -->
      <div class="grid md:grid-cols-3 gap-4 mb-10">
        <div class="bg-brand-accent/5 rounded-lg p-4 text-center">
          <div class="w-10 h-10 bg-brand-accent/20 rounded-full flex items-center justify-center mx-auto mb-3">
            <svg class="w-5 h-5 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101" />
              <path d="M10.172 13.828a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.102 1.101" />
            </svg>
          </div>
          <h3 class="font-semibold text-brand-navy text-sm">Dofollow Backlink</h3>
          <p class="text-xs text-brand-muted mt-1">A real SEO backlink to your website from a niche directory</p>
        </div>
        <div class="bg-brand-accent/5 rounded-lg p-4 text-center">
          <div class="w-10 h-10 bg-brand-accent/20 rounded-full flex items-center justify-center mx-auto mb-3">
            <svg class="w-5 h-5 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
            </svg>
          </div>
          <h3 class="font-semibold text-brand-navy text-sm">Edit Your Profile</h3>
          <p class="text-xs text-brand-muted mt-1">Update services, hours, photos, and contact info</p>
        </div>
        <div class="bg-brand-accent/5 rounded-lg p-4 text-center">
          <div class="w-10 h-10 bg-brand-accent/20 rounded-full flex items-center justify-center mx-auto mb-3">
            <svg class="w-5 h-5 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
            </svg>
          </div>
          <h3 class="font-semibold text-brand-navy text-sm">Priority Placement</h3>
          <p class="text-xs text-brand-muted mt-1">Stand out from other roofers in your city</p>
        </div>
      </div>

      <!-- Claim Form -->
      <form id="claim-form" class="space-y-5">
        <div>
          <label for="business-name" class="block text-sm font-medium text-brand-navy mb-1">Business Name</label>
          <input
            type="text"
            id="business-name"
            name="business_name"
            required
            class="w-full border border-slate-300 rounded-lg px-4 py-3 text-brand-navy focus:border-brand-accent focus:ring-1 focus:ring-brand-accent outline-none transition"
            placeholder="Your roofing company name"
          />
        </div>

        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <label for="contact-name" class="block text-sm font-medium text-brand-navy mb-1">Your Name</label>
            <input
              type="text"
              id="contact-name"
              name="contact_name"
              required
              class="w-full border border-slate-300 rounded-lg px-4 py-3 text-brand-navy focus:border-brand-accent focus:ring-1 focus:ring-brand-accent outline-none transition"
              placeholder="John Smith"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-brand-navy mb-1">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full border border-slate-300 rounded-lg px-4 py-3 text-brand-navy focus:border-brand-accent focus:ring-1 focus:ring-brand-accent outline-none transition"
              placeholder="john@yourcompany.com"
            />
          </div>
        </div>

        <div>
          <label for="phone" class="block text-sm font-medium text-brand-navy mb-1">Phone</label>
          <input
            type="tel"
            id="phone"
            name="phone"
            class="w-full border border-slate-300 rounded-lg px-4 py-3 text-brand-navy focus:border-brand-accent focus:ring-1 focus:ring-brand-accent outline-none transition"
            placeholder="(555) 123-4567"
          />
        </div>

        <div>
          <label for="updates" class="block text-sm font-medium text-brand-navy mb-1">What would you like to update?</label>
          <textarea
            id="updates"
            name="updates"
            rows="3"
            class="w-full border border-slate-300 rounded-lg px-4 py-3 text-brand-navy focus:border-brand-accent focus:ring-1 focus:ring-brand-accent outline-none transition"
            placeholder="e.g., Update our phone number, add photos, change service hours..."
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full bg-brand-accent text-brand-navy py-3 px-6 rounded-lg font-semibold text-lg hover:bg-brand-accent-light transition"
        >
          Submit Claim Request
        </button>
        <p class="text-xs text-brand-muted text-center">We'll verify your ownership and update your listing within 24 hours.</p>
      </form>

      <!-- Success message (hidden) -->
      <div id="claim-success" class="hidden text-center py-8">
        <div class="w-16 h-16 bg-brand-success/10 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-brand-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <h2 class="text-2xl font-bold text-brand-navy mb-2">Claim Submitted!</h2>
        <p class="text-brand-muted">We'll review your request and get back to you within 24 hours.</p>
      </div>
    </div>
  </div>

  <script>
    // Pre-fill business name from URL param
    const params = new URLSearchParams(window.location.search);
    const businessName = params.get('business');
    if (businessName) {
      const input = document.getElementById('business-name') as HTMLInputElement;
      if (input) input.value = businessName;
    }

    // Form submission
    const form = document.getElementById('claim-form');
    const success = document.getElementById('claim-success');

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      // In production, this would POST to a GHL webhook or n8n endpoint
      form.classList.add('hidden');
      success?.classList.remove('hidden');
    });
  </script>
</BaseLayout>
