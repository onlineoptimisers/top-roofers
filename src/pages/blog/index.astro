---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BreadcrumbNav from '../../components/BreadcrumbNav.astro';
import { BLOG_POSTS } from '../../lib/blog';

const posts = BLOG_POSTS.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<BaseLayout
  title="Roofing Guides & Articles | TopRoofers Blog"
  description="Expert roofing guides: costs, materials, contractor selection, maintenance tips, and more. Everything homeowners need to know about their roof."
>
  <div class="max-w-4xl mx-auto px-4 py-8">
    <BreadcrumbNav crumbs={[
      { label: 'Home', href: '/' },
      { label: 'Blog', href: '/blog/' },
    ]} />

    <h1 class="text-3xl font-bold text-brand-navy mb-2">Roofing Guides & Articles</h1>
    <p class="text-brand-muted mb-8">Everything you need to know about your roof - costs, materials, contractors, and maintenance.</p>

    <div class="space-y-6">
      {posts.map(post => (
        <a href={`/blog/${post.slug}/`} class="block bg-white rounded-xl shadow-sm hover:shadow-md border border-slate-100 p-6 transition-all hover:-translate-y-0.5 group">
          <div class="flex items-center gap-3 mb-2">
            <span class="text-xs bg-brand-accent/10 text-brand-accent px-2 py-1 rounded font-medium">{post.category}</span>
            <span class="text-xs text-brand-muted">{post.readTime} read</span>
            <span class="text-xs text-brand-muted">{new Date(post.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
          </div>
          <h2 class="text-lg font-semibold text-brand-navy group-hover:text-brand-accent transition">{post.title}</h2>
          <p class="text-sm text-brand-muted mt-2">{post.description}</p>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
