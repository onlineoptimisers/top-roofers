---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BreadcrumbNav from '../../components/BreadcrumbNav.astro';
import QuoteForm from '../../components/QuoteForm.astro';
import { BLOG_POSTS } from '../../lib/blog';

export function getStaticPaths() {
  return BLOG_POSTS.map(p => ({
    params: { slug: p.slug },
    props: { post: p },
  }));
}

const { post } = Astro.props;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.title,
  description: post.description,
  datePublished: post.date,
  author: { '@type': 'Organization', name: 'TopRoofers' },
  publisher: { '@type': 'Organization', name: 'TopRoofers' },
};
---

<BaseLayout
  title={`${post.title} | TopRoofers`}
  description={post.description}
  schema={schema}
>
  <div class="max-w-3xl mx-auto px-4 py-8">
    <BreadcrumbNav crumbs={[
      { label: 'Home', href: '/' },
      { label: 'Blog', href: '/blog/' },
      { label: post.title, href: `/blog/${post.slug}/` },
    ]} />

    <article>
      <div class="flex items-center gap-3 mb-4">
        <span class="text-xs bg-brand-accent/10 text-brand-accent px-2 py-1 rounded font-medium">{post.category}</span>
        <span class="text-xs text-brand-muted">{post.readTime} read</span>
        <span class="text-xs text-brand-muted">{new Date(post.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
      </div>

      <h1 class="text-3xl font-bold text-brand-navy mb-6">{post.title}</h1>

      <div class="prose prose-slate max-w-none [&_h2]:text-xl [&_h2]:font-bold [&_h2]:text-brand-navy [&_h2]:mt-8 [&_h2]:mb-3 [&_p]:text-brand-muted [&_p]:leading-relaxed [&_p]:mb-4 [&_ul]:text-brand-muted [&_ul]:mb-4 [&_ul]:space-y-1 [&_ol]:text-brand-muted [&_ol]:mb-4 [&_ol]:space-y-1 [&_li]:ml-5 [&_a]:text-brand-accent [&_a:hover]:underline [&_strong]:text-brand-navy" set:html={post.content} />
    </article>

    <QuoteForm />

    <!-- Related articles -->
    <div class="mt-12">
      <h2 class="text-xl font-bold text-brand-navy mb-4">More Roofing Guides</h2>
      <div class="grid md:grid-cols-2 gap-4">
        {BLOG_POSTS.filter(p => p.slug !== post.slug).slice(0, 4).map(p => (
          <a href={`/blog/${p.slug}/`} class="bg-white rounded-lg border border-slate-200 p-4 hover:border-brand-accent transition group">
            <span class="text-xs text-brand-accent font-medium">{p.category}</span>
            <h3 class="font-semibold text-sm text-brand-navy group-hover:text-brand-accent transition mt-1">{p.title}</h3>
          </a>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
