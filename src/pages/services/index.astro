---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BreadcrumbNav from '../../components/BreadcrumbNav.astro';
import { SERVICES } from '../../lib/services';
---

<BaseLayout
  title="Roofing Services Guide | Types of Roofing Work | TopRoofers"
  description="Learn about different roofing services: replacement, repair, metal roofing, commercial, flat roofs, storm damage, and inspections. Find the right contractor for your project."
>
  <div class="max-w-7xl mx-auto px-4 py-8">
    <BreadcrumbNav crumbs={[
      { label: 'Home', href: '/' },
      { label: 'Services', href: '/services/' },
    ]} />

    <h1 class="text-3xl font-bold text-brand-navy mb-2">Roofing Services</h1>
    <p class="text-brand-muted mb-8">Understand the different types of roofing work so you can find the right contractor for your project.</p>

    <div class="grid md:grid-cols-2 gap-6">
      {SERVICES.map(service => (
        <a href={`/services/${service.slug}/`} class="bg-white rounded-xl shadow-sm hover:shadow-md border border-slate-100 p-6 transition-all hover:-translate-y-0.5 group">
          <h2 class="text-lg font-semibold text-brand-navy group-hover:text-brand-accent transition mb-2">{service.title}</h2>
          <p class="text-sm text-brand-muted mb-3">{service.description}</p>
          <div class="flex items-center justify-between">
            <span class="text-xs bg-brand-accent/10 text-brand-accent px-3 py-1 rounded-full font-medium">{service.avgCost}</span>
            <span class="text-brand-accent text-sm">Learn more &rarr;</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
