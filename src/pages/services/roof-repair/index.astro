---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { SITE } from '../../../data/site';

const title = 'Roof Repair in Central Texas | Red Roan Construction';
const description =
  'Leak repair, storm damage patches, and emergency callouts across Hill Country and Austin. Red Roan Construction - (830) 388-1502 or (512) 779-0037.';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Roof Repair',
  description:
    'Leak detection and repair, storm and hail damage patches, flashing repairs, valley repairs, ventilation fixes, and emergency tarping across Central Texas.',
  provider: {
    '@type': 'LocalBusiness',
    name: SITE.name,
    telephone: [SITE.phones.hillCountry, SITE.phones.austin],
    email: SITE.email,
    url: SITE.url,
    address: {
      '@type': 'PostalAddress',
      addressLocality: SITE.address.city,
      addressRegion: SITE.address.state,
      addressCountry: 'US',
    },
    areaServed: SITE.address.serviceArea,
  },
  offers: {
    '@type': 'Offer',
    description: 'Free roof repair estimates for Central Texas homeowners',
    price: '0',
    priceCurrency: 'USD',
    name: 'Free Estimate',
  },
};

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'RoofingContractor',
  name: SITE.name,
  url: SITE.url,
  telephone: SITE.phones.hillCountry,
  email: SITE.email,
  address: {
    '@type': 'PostalAddress',
    addressLocality: SITE.address.city,
    addressRegion: SITE.address.state,
    addressCountry: 'US',
  },
  areaServed: [
    { '@type': 'Place', name: 'Texas Hill Country' },
    { '@type': 'Place', name: 'Austin Metro' },
    { '@type': 'Place', name: 'Central Texas' },
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Roof Repair Services',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Leak Detection and Repair' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Storm and Hail Damage Repair' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Emergency Roof Tarping' } },
    ],
  },
};

const repairTypes = [
  {
    icon: 'M9 13h6m-3-3v6m5 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
    title: 'Leak Detection & Repair',
    desc: 'We locate the source of the leak - not just the symptom - and fix it properly. Interior water stains often trace to a different point on the roof than where the water enters.',
  },
  {
    icon: 'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064',
    title: 'Storm & Hail Damage Patches',
    desc: 'After a Texas hailstorm or high-wind event, we assess the full extent of damage and repair or patch affected sections before water gets in.',
  },
  {
    icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15',
    title: 'Flashing Repairs',
    desc: 'Failed flashing around chimneys, vents, skylights, and walls is one of the most common causes of leaks. We re-seal or replace flashing that has lifted, cracked, or corroded.',
  },
  {
    icon: 'M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2',
    title: 'Valley Repairs',
    desc: 'Roof valleys channel significant water volume and wear faster than flat sections. We repair or replace damaged valley flashing and shingles to restore proper water shedding.',
  },
  {
    icon: 'M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4',
    title: 'Ventilation Fixes',
    desc: 'Poor roof ventilation causes premature shingle failure and moisture buildup in your attic. We inspect and repair ridge vents, soffit vents, and attic ventilation systems.',
  },
  {
    icon: 'M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4',
    title: 'Emergency Tarping',
    desc: 'If your roof has been compromised by a storm or sudden damage, we can tarp the affected area to protect your home while we arrange a permanent repair.',
  },
];

const processSteps = [
  {
    icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2',
    step: '01',
    title: 'Assessment',
    desc: 'We inspect the roof to identify exactly what is damaged and what caused it. We look at the full picture, not just the obvious spot.',
  },
  {
    icon: 'M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z',
    step: '02',
    title: 'Photo Documentation',
    desc: 'We photograph all damage before and after repairs. This protects you if you need to file an insurance claim and gives you a clear record of the work done.',
  },
  {
    icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
    step: '03',
    title: 'Written Quote',
    desc: 'You get a written quote before any work starts. The quote covers parts and labour. No verbal estimates that change when the invoice arrives.',
  },
  {
    icon: 'M5 13l4 4L19 7',
    step: '04',
    title: 'Repair + Cleanup',
    desc: 'We complete the repair and clean up completely. Before we leave, we walk you through what was done and confirm you are satisfied.',
  },
];

const faqs = [
  {
    q: 'How quickly can you respond to a leak?',
    a: 'We aim for same-day response when possible, particularly for active leaks. Call us directly on (830) 388-1502 (Hill Country) or (512) 779-0037 (Austin) and we will do our best to get someone out that day. Next-morning response is typical when same-day is not possible.',
  },
  {
    q: 'Will my insurance cover roof repair?',
    a: 'It depends on the cause. Damage from sudden events like hail, wind, or falling debris is typically covered under a standard homeowners policy. Damage from gradual wear, lack of maintenance, or pre-existing issues usually is not. We photograph and document all damage thoroughly, which gives you the best evidence base for a claim. We are happy to explain what we are seeing and help you understand whether a claim is likely to be approved.',
  },
  {
    q: 'How long does a roof repair take?',
    a: 'Most repairs are complete in 2-4 hours. Larger patch jobs or repairs that involve multiple sections may take a full day. We will give you a realistic time estimate when we quote the job.',
  },
  {
    q: 'Do repairs come with a warranty?',
    a: 'Yes. The same 5-year workmanship warranty that applies to our replacement work covers our repair work too. If our repair fails within 5 years due to our workmanship, we come back and fix it at no charge. Materials also carry manufacturer warranties where applicable.',
  },
];
---

<BaseLayout title={title} description={description} schema={[serviceSchema, localBusinessSchema]} canonical={`${SITE.url}/services/roof-repair/`}>

  <!-- Hero -->
  <section class="bg-brand-navy text-white py-20 md:py-28 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: url(\"data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E\")"></div>
    <div class="max-w-7xl mx-auto px-4 relative">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 bg-brand-accent/20 text-brand-accent px-3 py-1 rounded-full text-sm font-semibold mb-6 border border-brand-accent/30">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
          Emergency Repairs Available
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-tight mb-6">
          Roof Leaks<br />
          <span class="text-brand-accent">Fixed Fast</span>
        </h1>
        <p class="text-lg md:text-xl text-white/80 leading-relaxed mb-10 max-w-2xl">
          Leak repairs, storm damage patches, and emergency callouts across the Hill Country and Austin metro. We respond same day when possible - because a leak that waits gets worse.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href={`tel:${SITE.phones.hillCountryTel}`}
            class="inline-flex items-center justify-center gap-3 bg-brand-accent text-white px-7 py-4 rounded-xl font-bold text-lg hover:bg-[#c0533b] transition shadow-lg"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Hill Country: {SITE.phones.hillCountry}
          </a>
          <a
            href={`tel:${SITE.phones.austinTel}`}
            class="inline-flex items-center justify-center gap-3 bg-white/10 text-white border border-white/25 px-7 py-4 rounded-xl font-bold text-lg hover:bg-white/20 transition"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Austin: {SITE.phones.austin}
          </a>
        </div>
        <p class="mt-5 text-white/50 text-sm">Same-day response when possible. 5-year workmanship warranty on all repair work.</p>
      </div>
    </div>
  </section>

  <!-- Trust bar -->
  <div class="bg-brand-warm border-b border-brand-navy/10">
    <div class="max-w-7xl mx-auto px-4 py-5">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-center text-sm">
        {[
          { label: 'Same-Day Response', value: 'When Possible' },
          { label: 'Workmanship Warranty', value: '5-Year' },
          { label: 'Repairs Completed', value: '1,000+' },
          { label: 'Free Estimates', value: 'Always' },
        ].map(item => (
          <div class="py-2">
            <div class="text-2xl font-extrabold text-brand-accent">{item.value}</div>
            <div class="text-brand-navy/60 mt-0.5">{item.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Repair Types -->
  <section class="py-20 bg-brand-light">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-extrabold text-brand-navy mb-4">Common Repair Types</h2>
        <p class="text-brand-navy/60 max-w-xl mx-auto text-lg">From a small leak to storm damage across multiple sections - we handle the full range of residential roof repairs.</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {repairTypes.map(repair => (
          <div class="bg-white rounded-2xl p-7 shadow-sm border border-brand-navy/8 hover:border-brand-accent/30 hover:shadow-md transition group">
            <div class="w-12 h-12 bg-brand-accent/10 rounded-xl flex items-center justify-center mb-4 group-hover:bg-brand-accent/15 transition">
              <svg class="w-6 h-6 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d={repair.icon} />
              </svg>
            </div>
            <h3 class="font-bold text-brand-navy text-lg mb-2">{repair.title}</h3>
            <p class="text-brand-navy/65 text-sm leading-relaxed">{repair.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Repair vs Replace -->
  <section class="py-20 bg-brand-warm">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-extrabold text-brand-navy mb-4">Repair or Replace?</h2>
        <p class="text-brand-navy/60 max-w-xl mx-auto text-lg">We will give you a straight answer - not the one that makes us more money.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-6 mb-10">
        <!-- Repair makes sense -->
        <div class="bg-white rounded-2xl p-8 border-2 border-green-500/30 shadow-sm">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 bg-green-500/10 rounded-xl flex items-center justify-center">
              <svg class="w-5 h-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <h3 class="text-lg font-bold text-brand-navy">Repair Usually Makes Sense When...</h3>
          </div>
          <ul class="space-y-3">
            {[
              'Less than 20% of the roof surface is damaged',
              'The roof is under 15 years old',
              'Damage is localised to one section or side',
              'The underlying deck and structure are sound',
              'You plan to sell within 2-3 years and need it to pass inspection',
            ].map(item => (
              <li class="flex items-start gap-3 text-sm text-brand-navy/75">
                <svg class="w-4 h-4 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- Replacement makes sense -->
        <div class="bg-white rounded-2xl p-8 border-2 border-brand-accent/25 shadow-sm">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 bg-brand-accent/10 rounded-xl flex items-center justify-center">
              <svg class="w-5 h-5 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-lg font-bold text-brand-navy">Replacement Is Often Better When...</h3>
          </div>
          <ul class="space-y-3">
            {[
              'More than 20% of the roof surface is damaged or worn',
              'The roof is over 20 years old',
              'You have had multiple repairs in the last few years',
              'The deck or rafters show signs of rot or structural weakness',
              'Energy bills are high and better insulation is a goal',
            ].map(item => (
              <li class="flex items-start gap-3 text-sm text-brand-navy/75">
                <svg class="w-4 h-4 text-brand-accent flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>

      <div class="bg-brand-navy text-white rounded-2xl p-8 text-center">
        <p class="text-lg text-white/85 leading-relaxed">
          <strong class="text-white">We will tell you honestly which makes more sense.</strong> If a repair is the right call, we will say so - even if a replacement would be more revenue for us. Our business runs on referrals and that only works if we treat people right.
        </p>
      </div>
    </div>
  </section>

  <!-- Emergency Repairs -->
  <section class="py-20 bg-brand-accent text-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <div class="w-16 h-16 bg-white/15 rounded-2xl flex items-center justify-center mx-auto mb-6">
        <svg class="w-8 h-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M13 10V3L4 14h7v7l9-11h-7z" />
        </svg>
      </div>
      <h2 class="text-3xl md:text-4xl font-extrabold mb-5">Emergency Roof Repairs</h2>
      <p class="text-xl text-white/85 leading-relaxed mb-8 max-w-2xl mx-auto">
        We respond to leak emergencies. Call us and we will do our best to get someone out the same day. A leak that gets overnight attention does far less damage than one that waits a week.
      </p>
      <p class="text-white/70 text-lg mb-10">
        If we cannot get out same day, we will give you clear guidance on steps to minimise damage in the meantime and schedule the earliest possible appointment.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={`tel:${SITE.phones.hillCountryTel}`}
          class="inline-flex items-center justify-center gap-3 bg-white text-brand-accent px-8 py-4 rounded-xl font-bold text-lg hover:bg-brand-warm transition shadow-lg"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Hill Country: {SITE.phones.hillCountry}
        </a>
        <a
          href={`tel:${SITE.phones.austinTel}`}
          class="inline-flex items-center justify-center gap-3 bg-white/15 text-white border border-white/30 px-8 py-4 rounded-xl font-bold text-lg hover:bg-white/25 transition"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Austin: {SITE.phones.austin}
        </a>
      </div>
    </div>
  </section>

  <!-- Repair Process -->
  <section class="py-20 bg-brand-light">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-extrabold text-brand-navy mb-4">Our Repair Process</h2>
        <p class="text-brand-navy/60 max-w-xl mx-auto text-lg">Four straightforward steps. We keep it simple and keep you informed throughout.</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 max-w-5xl mx-auto">
        {processSteps.map((step, i) => (
          <div class="bg-white rounded-2xl p-7 shadow-sm border border-brand-navy/8 relative text-center">
            <div class="absolute top-5 right-5 text-5xl font-extrabold text-brand-navy/5 leading-none select-none">{step.step}</div>
            <div class="w-12 h-12 bg-brand-accent/10 rounded-xl flex items-center justify-center mb-4 mx-auto">
              <svg class="w-6 h-6 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d={step.icon} />
              </svg>
            </div>
            <h3 class="font-bold text-brand-navy text-lg mb-2">{step.title}</h3>
            <p class="text-brand-navy/65 text-sm leading-relaxed">{step.desc}</p>
            {i < processSteps.length - 1 && (
              <div class="hidden lg:block absolute top-1/2 -right-3 w-6 h-0.5 bg-brand-accent/30 transform -translate-y-1/2 z-10"></div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Red Roan for Repairs -->
  <section class="py-20 bg-brand-warm">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-extrabold text-brand-navy mb-4">What You Get With Red Roan</h2>
        <p class="text-brand-navy/60 max-w-xl mx-auto text-lg">The same standards we apply to replacements apply to every repair job - no matter how small.</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          {
            icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
            title: '5-Year Workmanship Warranty',
            desc: 'Every repair we do is covered by a 5-year workmanship warranty. If it fails due to our work, we fix it at no charge.',
          },
          {
            icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z',
            title: 'Local Crews Only',
            desc: 'No subcontractors. The team that quotes the job is the team that does the work. You know who is on your roof.',
          },
          {
