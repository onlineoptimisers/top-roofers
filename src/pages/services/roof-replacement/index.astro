---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { SITE } from '../../../data/site';

const title = 'Roof Replacement in Central Texas | Red Roan Construction';
const description =
  'Full asphalt shingle and metal roof replacement for Central Texas homeowners. Hill Country (830) 388-1502 · Austin (512) 779-0037. Free estimates.';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Roof Replacement',
  description:
    'Full asphalt shingle and metal roof replacement for residential properties across Central Texas, including the Hill Country and Austin metro.',
  provider: {
    '@type': 'LocalBusiness',
    name: SITE.name,
    telephone: [SITE.phones.hillCountry, SITE.phones.austin],
    email: SITE.email,
    url: SITE.url,
    address: {
      '@type': 'PostalAddress',
      addressLocality: SITE.address.city,
      addressRegion: SITE.address.state,
      addressCountry: 'US',
    },
    areaServed: SITE.address.serviceArea,
  },
  offers: {
    '@type': 'Offer',
    description: 'Free roof replacement estimates for Central Texas homeowners',
    price: '0',
    priceCurrency: 'USD',
    name: 'Free Estimate',
  },
};

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'RoofingContractor',
  name: SITE.name,
  url: SITE.url,
  telephone: SITE.phones.hillCountry,
  email: SITE.email,
  address: {
    '@type': 'PostalAddress',
    addressLocality: SITE.address.city,
    addressRegion: SITE.address.state,
    addressCountry: 'US',
  },
  areaServed: [
    { '@type': 'Place', name: 'Texas Hill Country' },
    { '@type': 'Place', name: 'Austin Metro' },
    { '@type': 'Place', name: 'Central Texas' },
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Roofing Services',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Asphalt Shingle Roof Replacement' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Metal Roof Replacement' } },
    ],
  },
};

const processSteps = [
  {
    icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2',
    step: '01',
    title: 'Free Inspection',
    desc: 'We come out and inspect your roof at no charge. We check for damage, assess the overall condition, and give you an honest picture of what you are working with.',
  },
  {
    icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
    step: '02',
    title: 'Written Estimate',
    desc: 'You receive a clear, itemised written estimate before any work begins. No verbal quotes, no surprises on the final invoice.',
  },
  {
    icon: 'M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01',
    step: '03',
    title: 'Material Selection',
    desc: 'We walk you through your options - shingle style, colour, manufacturer - and help you pick what works best for your home, climate, and budget.',
  },
  {
    icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0',
    step: '04',
    title: 'Permit (if required)',
    desc: 'Some Central Texas counties require a roofing permit. If yours does, we handle the paperwork. You do not have to chase the county building department.',
  },
  {
    icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6',
    step: '05',
    title: 'Installation (1-2 Days)',
    desc: 'Our crew arrives on time, protects your property, and installs your new roof. Most residential replacements are complete in one to two days.',
  },
  {
    icon: 'M5 13l4 4L19 7',
    step: '06',
    title: 'Final Walkthrough + Warranty',
    desc: 'We walk the job with you when it is done - you see the finished roof, we confirm the cleanup is complete, and we hand over your 5-year workmanship warranty in writing.',
  },
];

const faqs = [
  {
    q: 'How long does a roof replacement take?',
    a: 'Most residential roof replacements in Central Texas are complete in one to two days. Larger homes, complex roof lines, or weather delays can extend that slightly. We will give you a realistic timeline in your written estimate.',
  },
  {
    q: 'Do I need a permit for a roof replacement?',
    a: 'It depends on the county. Some Hill Country and Austin area counties require a permit for a full replacement; others do not. We know the local requirements and handle all permit paperwork on your behalf at no extra charge.',
  },
  {
    q: 'Can you match my existing shingles for a partial replacement?',
    a: "Usually, yes. For partial replacements we bring shingle samples to match your existing colour and profile as closely as possible. Exact matches depend on whether the manufacturer still produces that line, but we'll be upfront about the options before any work starts.",
  },
  {
    q: "What is the difference between architectural and 3-tab shingles?",
    a: '3-tab shingles are flat, lightweight, and have a uniform appearance. They are less expensive but have a shorter lifespan (20-25 years) and perform less well in high winds. Architectural (dimensional) shingles are thicker, have a layered look, and typically carry a 30-year warranty. Most Central Texas homeowners choose architectural shingles for the combination of durability, wind resistance, and kerb appeal.',
  },
  {
    q: 'Does the warranty cover both materials and labour?',
    a: "Our 5-year workmanship warranty covers our installation work - the labour and the way the roof is put together. Materials carry a separate manufacturer's warranty that typically runs 25-50 years depending on the product. We explain both warranties clearly before installation begins.",
  },
];
---

<BaseLayout title={title} description={description} schema={[serviceSchema, localBusinessSchema]} canonical={`${SITE.url}/services/roof-replacement/`}>

  <!-- Hero -->
  <section class="bg-brand-navy text-white py-20 md:py-28 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: url(\"data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E\")"></div>
    <div class="max-w-7xl mx-auto px-4 relative">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 bg-brand-accent/20 text-brand-accent px-3 py-1 rounded-full text-sm font-semibold mb-6 border border-brand-accent/30">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M3 21h18M3 21V9l9-7 9 7v12M9 21v-6h6v6" />
          </svg>
          Central Texas Roofing Contractors
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-tight mb-6">
          Roof Replacement<br />
          <span class="text-brand-accent">Done Right</span>
        </h1>
        <p class="text-lg md:text-xl text-white/80 leading-relaxed mb-10 max-w-2xl">
          Asphalt shingle and metal roof replacements for Central Texas homeowners. Over 10 years of local experience, a 5-year workmanship warranty, and crews who show up when they say they will.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href={`tel:${SITE.phones.hillCountryTel}`}
            class="inline-flex items-center justify-center gap-3 bg-brand-accent text-white px-7 py-4 rounded-xl font-bold text-lg hover:bg-[#c0533b] transition shadow-lg"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Hill Country: {SITE.phones.hillCountry}
          </a>
          <a
            href={`tel:${SITE.phones.austinTel}`}
            class="inline-flex items-center justify-center gap-3 bg-white/10 text-white border border-white/25 px-7 py-4 rounded-xl font-bold text-lg hover:bg-white/20 transition"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Austin: {SITE.phones.austin}
          </a>
        </div>
        <p class="mt-5 text-white/50 text-sm">Free estimates. No pressure. Honest advice.</p>
      </div>
    </div>
  </section>

  <!-- Trust bar -->
  <div class="bg-brand-warm border-b border-brand-navy/10">
    <div class="max-w-7xl mx-auto px-4 py-5">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-center text-sm">
        {[
          { label: 'Years Experience', value: '10+' },
          { label: 'Workmanship Warranty', value: '5-Year' },
          { label: 'Roofs Installed', value: '500+' },
          { label: 'Free Estimates', value: 'Always' },
        ].map(item => (
          <div class="py-2">
            <div class="text-2xl font-extrabold text-brand-accent">{item.value}</div>
            <div class="text-brand-navy/60 mt-0.5">{item.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Material Options -->
  <section class="py-20 bg-brand-light">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-extrabold text-brand-navy mb-4">Two Roofing Systems. One Honest Recommendation.</h2>
        <p class="text-brand-navy/60 max-w-2xl mx-auto text-lg">We install both asphalt shingles and metal roofing. We will tell you which makes more sense for your home, your budget, and the Central Texas climate.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <!-- Asphalt -->
        <div class="bg-white rounded-2xl shadow-sm border border-brand-navy/8 overflow-hidden">
          <div class="bg-brand-navy px-8 py-6">
            <div class="flex items-center gap-3 mb-2">
              <div class="w-10 h-10 bg-brand-accent/20 rounded-xl flex items-center justify-center">
                <svg class="w-5 h-5 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M3 21h18M3 21V9l9-7 9 7v12M9 21v-6h6v6" />
                </svg>
              </div>
              <span class="text-white/60 text-sm font-medium uppercase tracking-wide">Most Popular</span>
            </div>
            <h3 class="text-2xl font-bold text-white">Asphalt Shingle Roofing</h3>
          </div>
          <div class="px-8 py-7">
            <p class="text-brand-navy/70 leading-relaxed mb-6">
              Asphalt shingles are the most popular roofing material in Texas for good reason: they are cost-effective, straightforward to install, and perform reliably in the Texas heat when the right product is chosen. For most Central Texas homeowners, asphalt is the practical choice.
            </p>
            <ul class="space-y-3">
              {[
                'Most cost-effective option upfront',
                '25-30 year lifespan on architectural shingles',
                'Wide range of colours and profiles to match your home',
                'Handles Texas heat well with proper attic ventilation',
                'Faster installation - most jobs done in a day',
                'Wide availability of matching product for future repairs',
              ].map(item => (
                <li class="flex items-start gap-3 text-sm text-brand-navy/80">
                  <svg class="w-5 h-5 text-brand-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path d="M5 13l4 4L19 7" />
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
            <div class="mt-7 p-4 bg-brand-warm rounded-xl text-sm text-brand-navy/70">
              <strong class="text-brand-navy">Best for:</strong> homeowners looking for a quality roof at the most competitive price point, standard residential homes, re-roofing projects where speed matters.
            </div>
          </div>
        </div>

        <!-- Metal -->
        <div class="bg-white rounded-2xl shadow-sm border border-brand-accent/20 overflow-hidden ring-2 ring-brand-accent/15">
          <div class="bg-brand-accent px-8 py-6">
            <div class="flex items-center gap-3 mb-2">
              <div class="w-10 h-10 bg-white/20 rounded-xl flex items-center justify-center">
                <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
              </div>
              <span class="text-white/80 text-sm font-medium uppercase tracking-wide">Premium Option</span>
            </div>
            <h3 class="text-2xl font-bold text-white">Metal Roofing</h3>
          </div>
          <div class="px-8 py-7">
            <p class="text-brand-navy/70 leading-relaxed mb-6">
              Metal roofing is the long-term investment choice. It costs more upfront but outperforms asphalt on lifespan, energy efficiency, and low maintenance. In the Hill Country especially - where you have long hot summers and periodic severe weather - metal roofing earns its premium over time.
            </p>
            <ul class="space-y-3">
              {[
                '40-70 year lifespan - likely the last roof you will ever need',
                'Reflects heat and reduces cooling costs in Texas summers',
                'Excellent performance in high winds and hail',
                'Ideal for Hill Country properties and rural homes',
                'Very low maintenance over its lifetime',
                'Increases home resale value',
              ].map(item => (
                <li class="flex items-start gap-3 text-sm text-brand-navy/80">
                  <svg class="w-5 h-5 text-brand-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path d="M5 13l4 4L19 7" />
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
            <div class="mt-7 p-4 bg-brand-warm rounded-xl text-sm text-brand-navy/70">
              <strong class="text-brand-navy">Best for:</strong> Hill Country properties, homeowners planning to stay long-term, anyone prioritising energy savings and reduced maintenance, rural and acreage homes.
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Process -->
  <section class="py-20 bg-brand-warm">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-extrabold text-brand-navy mb-4">Our Replacement Process</h2>
        <p class="text-brand-navy/60 max-w-xl mx-auto text-lg">Six straightforward steps from first call to final walkthrough. No surprises, no runaround.</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {processSteps.map(step => (
          <div class="bg-white rounded-2xl p-7 shadow-sm border border-brand-navy/8 relative">
            <div class="absolute top-6 right-6 text-5xl font-extrabold text-brand-navy/5 leading-none select-none">{step.step}</div>
            <div class="w-12 h-12 bg-brand-accent/10 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d={step.icon} />
              </svg>
            </div>
            <h3 class="font-bold text-brand-navy text-lg mb-2">{step.title}</h3>
            <p class="text-brand-navy/65 text-sm leading-relaxed">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Red Roan -->
  <section class="py-20 bg-brand-light">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-extrabold text-brand-navy mb-5">
            Why Central Texas Homeowners<br />
            <span class="text-brand-accent">Choose Red Roan</span>
          </h2>
          <p class="text-brand-navy/65 text-lg leading-relaxed mb-8">
            We are a local company. Our crews work in the Hill Country and Austin area year-round. We know the climate, the building codes, and what roofing products hold up here. You will not get handed off to a subcontractor.
          </p>
          <div class="space-y-5">
            {[
              {
                title: '5-Year Workmanship Warranty',
                desc: 'Every roof we install is backed by a written 5-year warranty on our workmanship - separate from and in addition to the manufacturer product warranty.',
              },
              {
                title: 'Local Crews, No Subcontractors',
                desc: 'The people who show up are our employees. We do not farm your job out. That means consistent quality and a crew that stands behind its work.',
              },
              {
                title: 'Clean Job Sites',
                desc: 'We use magnetic rollers and do a full sweep after every job. Your yard, driveway, and landscaping should look the same as before we arrived.',
              },
              {
                title: 'Insurance Claim Experience',
                desc: 'We have worked through hundreds of insurance claims across Central Texas. We document damage thoroughly and communicate directly with adjusters when needed.',
              },
              {
                title: 'Honest Assessments',
                desc: 'We will tell you if a repair is the smarter move rather than a full replacement. Our long-term business depends on referrals, not one-time upsells.',
              },
            ].map(item => (
              <div class="flex gap-4">
                <div class="w-8 h-8 bg-brand-accent/10 rounded-lg flex-shrink-0 flex items-center justify-center mt-0.5">
                  <svg class="w-4 h-4 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <div>
                  <h4 class="font-bold text-brand-navy mb-1">{item.title}</h4>
                  <p class="text-brand-navy/65 text-sm leading-relaxed">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="space-y-4">
          <div class="bg-brand-navy text-white rounded-2xl p-8">
            <h3 class="text-xl font-bold mb-4">Our Guarantee</h3>
            <p class="text-white/75 leading-relaxed mb-6">
              Every roof replacement comes with a written 5-year workmanship warranty. If our installation causes a problem within 5 years, we come back and fix it. No charge. No argument.
            </p>
            <div class="flex items-center gap-3 text-sm text-white/60">
              <svg class="w-5 h-5 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
              Written warranty provided at project completion
            </div>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div class="bg-brand-warm rounded-2xl p-6 text-center border border-brand-navy/8">
              <div class="text-3xl font-extrabold text-brand-accent mb-1">500+</div>
              <div class="text-sm text-brand-navy/65">Roofs Replaced</div>
            </div>
            <div class="bg-brand-warm rounded-2xl p-6 text-center border border-brand-navy/8">
              <div class="text-3xl font-extrabold text-brand-accent mb-1">10+</div>
              <div class="text-sm text-brand-navy/65">Years Serving Central Texas</div>
            </div>
            <div class="bg-brand-warm rounded-2xl p-6 text-center border border-brand-navy/8">
              <div class="text-3xl font-extrabold text-brand-accent mb-1">5★</div>
              <div class="text-sm text-brand-navy/65">Average Customer Rating</div>
            </div>
            <div class="bg-brand-warm rounded-2xl p-6 text-center border border-brand-navy/8">
              <div class="text-3xl font-extrabold text-brand-accent mb-1">$0</div>
              <div class="text-sm text-brand-navy/65">Cost for Your Estimate</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Area -->
  <section class="py-20 bg-brand-navy text-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-extrabold mb-4">Service Area</h2>
        <p class="text-white/60 max-w-xl mx-auto text-lg">Two dedicated crews serving Central Texas. Most estimates scheduled within 2-3 business days.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <!-- Hill Country Team -->
        <div class="bg-white/8 rounded-2xl p-8 border border-white/10">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 bg-brand-accent/20 rounded-xl flex items-center justify-center">
              <svg class="w-5 h-5 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold">Hill Country Team</h3>
          </div>
          <ul class="space-y-2 text-white/70 text-sm mb-7">
            {['Copperas Cove', 'Killeen', 'Lampasas', 'Burnet', 'Marble Falls', 'Mason', 'Fredericksburg', 'Kerrville', 'Llano', 'Brady'].map(city => (
              <li class="flex items-center gap-2">
                <svg class="w-3 h-3 text-brand-accent flex-shrink-0" fill="currentColor" viewBox="0 0 8 8">
                  <circle cx="4" cy="4" r="4" />
                </svg>
                {city}
              </li>
            ))}
          </ul>
          <a
            href={`tel:${SITE.phones.hillCountryTel}`}
            class="flex items-center justify-center gap-2 bg-brand-accent text-white py-3.5 px-6 rounded-xl font-bold hover:bg-[#c0533b] transition w-full"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            {SITE.phones.hillCountry}
          </a>
        </div>

        <!-- Austin Team -->
