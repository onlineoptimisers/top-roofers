---
// No props required — standalone contact form
---

<div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-6 md:p-8">
  <div class="mb-6">
    <h2 class="text-2xl font-bold text-[#1a2744] mb-1">Get a Free Quote</h2>
    <p class="text-sm text-[#6b7280]">Tell us about your roof and we'll get back to you within 24 hours.</p>
  </div>

  <form action="#" method="post" class="flex flex-col gap-4">

    <!-- Name -->
    <div class="flex flex-col gap-1">
      <label for="qf-name" class="text-sm font-semibold text-[#1a2744]">Name</label>
      <input
        id="qf-name"
        type="text"
        name="name"
        placeholder="Your full name"
        required
        class="w-full rounded-lg border border-slate-200 px-4 py-3 text-sm text-[#1a2744] placeholder:text-slate-400 outline-none focus:ring-2 focus:ring-[#a6442e] focus:border-transparent transition"
      />
    </div>

    <!-- Phone -->
    <div class="flex flex-col gap-1">
      <label for="qf-phone" class="text-sm font-semibold text-[#1a2744]">Phone</label>
      <input
        id="qf-phone"
        type="tel"
        name="phone"
        placeholder="(000) 000-0000"
        required
        class="w-full rounded-lg border border-slate-200 px-4 py-3 text-sm text-[#1a2744] placeholder:text-slate-400 outline-none focus:ring-2 focus:ring-[#a6442e] focus:border-transparent transition"
      />
    </div>

    <!-- Email -->
    <div class="flex flex-col gap-1">
      <label for="qf-email" class="text-sm font-semibold text-[#1a2744]">Email</label>
      <input
        id="qf-email"
        type="email"
        name="email"
        placeholder="you@example.com"
        required
        class="w-full rounded-lg border border-slate-200 px-4 py-3 text-sm text-[#1a2744] placeholder:text-slate-400 outline-none focus:ring-2 focus:ring-[#a6442e] focus:border-transparent transition"
      />
    </div>

    <!-- Service -->
    <div class="flex flex-col gap-1">
      <label for="qf-service" class="text-sm font-semibold text-[#1a2744]">Service</label>
      <select
        id="qf-service"
        name="service"
        required
        class="w-full rounded-lg border border-slate-200 px-4 py-3 text-sm text-[#1a2744] outline-none focus:ring-2 focus:ring-[#a6442e] focus:border-transparent transition bg-white"
      >
        <option value="" disabled selected>Select a service...</option>
        <option value="roof-replacement">Roof Replacement</option>
        <option value="storm-damage">Storm Damage</option>
        <option value="roof-repair">Roof Repair</option>
        <option value="inspection">Inspection</option>
        <option value="other">Other</option>
      </select>
    </div>

    <!-- Message -->
    <div class="flex flex-col gap-1">
      <label for="qf-message" class="text-sm font-semibold text-[#1a2744]">Message <span class="font-normal text-[#6b7280]">(optional)</span></label>
      <textarea
        id="qf-message"
        name="message"
        rows="4"
        placeholder="Describe your project or any questions you have..."
        class="w-full rounded-lg border border-slate-200 px-4 py-3 text-sm text-[#1a2744] placeholder:text-slate-400 outline-none focus:ring-2 focus:ring-[#a6442e] focus:border-transparent transition resize-none"
      ></textarea>
    </div>

    <!-- Submit -->
    <button
      type="submit"
      class="w-full rounded-lg px-6 py-3.5 text-sm font-bold text-white transition hover:opacity-90 active:scale-[0.98]"
      style="background-color: #a6442e;"
    >
      Get Free Quote
    </button>

  </form>
</div>
