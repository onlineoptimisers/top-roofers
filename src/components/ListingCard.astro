---
import ReviewStars from './ReviewStars.astro';

interface Props {
  listing: {
    slug: string;
    title: string;
    address: string;
    city: string;
    state: string;
    rating: number;
    reviews: number;
    phone: string;
    domain: string;
    category: string;
  };
  citySlug: string;
  stateSlug: string;
}

const { listing, citySlug, stateSlug } = Astro.props;
const listingUrl = `/states/${stateSlug}/${citySlug}/${listing.slug}/`;
---

<a href={listingUrl} class="block bg-white rounded-xl shadow-sm hover:shadow-md border border-slate-100 p-5 transition-all hover:-translate-y-0.5 group">
  <div class="flex items-start justify-between gap-4">
    <div class="flex-1 min-w-0">
      <h3 class="font-semibold text-lg text-brand-navy group-hover:text-brand-accent transition truncate">
        {listing.title}
      </h3>
      <p class="text-sm text-brand-muted mt-1 truncate">{listing.address}</p>
      <div class="mt-2">
        <ReviewStars rating={listing.rating} reviews={listing.reviews} size="sm" />
      </div>
      <div class="flex items-center gap-3 mt-3 text-xs text-brand-muted">
        <span class="bg-slate-100 px-2 py-1 rounded">{listing.category}</span>
        {listing.phone && <span>{listing.phone}</span>}
      </div>
    </div>
    <div class="flex-shrink-0 w-12 h-12 bg-brand-accent/10 rounded-lg flex items-center justify-center">
      <svg class="w-6 h-6 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path d="M3 21h18M3 21V9l9-7 9 7v12M9 21v-6h6v6" />
      </svg>
    </div>
  </div>
</a>
