---
interface Crumb {
  label: string;
  href: string;
}

interface Props {
  crumbs: Crumb[];
}

const { crumbs } = Astro.props;

const schemaItems = crumbs.map((crumb, i) => ({
  '@type': 'ListItem',
  position: i + 1,
  name: crumb.label,
  item: new URL(crumb.href, 'https://top-roofers.pages.dev').toString(),
}));

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: schemaItems,
};
---

<nav aria-label="Breadcrumb" class="text-sm text-brand-muted py-3">
  <ol class="flex items-center gap-1 flex-wrap">
    {crumbs.map((crumb, i) => (
      <li class="flex items-center gap-1">
        {i > 0 && <span class="text-slate-300">/</span>}
        {i === crumbs.length - 1 ? (
          <span class="text-brand-navy font-medium">{crumb.label}</span>
        ) : (
          <a href={crumb.href} class="hover:text-brand-accent transition">{crumb.label}</a>
        )}
      </li>
    ))}
  </ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
